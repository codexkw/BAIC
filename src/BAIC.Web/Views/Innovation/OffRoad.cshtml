@{
    ViewData["Title"] = "Off Road";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/offroad.css" asp-append-version="true" />
}

<!-- HERO -->
<section class="or-hero">
  <img src="~/images/baicglobal/_nuxt/kv.BYRZBGpE.jpg" alt="BAIC Off Road">
  <div class="or-hero-overlay"></div>
  <h1 data-i18n="offroad.heroHeading">OFF ROAD</h1>
</section>

<!-- LAYERED COMPOSITION (mirrors original Nuxt center_box) -->
<section class="or-canvas">

  <!-- Background row -->
  <div class="img_01"><img src="~/images/baicglobal/_nuxt/001.CRNebkBa.png" alt=""></div>

  <!-- Top brushstroke band with overlaid section heading -->
  <div class="img_02">
    <img src="~/images/baicglobal/_nuxt/002.UedxcHu2.png" alt="">
    <p class="title title_1_p" data-i18n="offroad.vehicleIntegration">Vehicle Integration Capability</p>
  </div>

  <!-- Narrow vertical decoration on left -->
  <div class="img_03"><img src="~/images/baicglobal/_nuxt/003.Cc2PLlew.png" alt=""></div>

  <!-- Circular ink frame containing the BJ40 SE car (img_06 nested inside) -->
  <div class="img_04">
    <img src="~/images/baicglobal/_nuxt/004.BbmKtSCA.png" alt="">
    <img class="img_06" src="~/images/baicglobal/_nuxt/006.DFcxStcK.png" alt="">
  </div>

  <!-- 3 bullet rows -->
  <div class="text_1 content_text">
    <img class="img_05" src="~/images/baicglobal/_nuxt/005.KsEu9dks.png" alt="">
    <span data-i18n="offroad.bullet1">Comprehensive application of computer-aided development methods;</span>
  </div>
  <div class="text_2 content_text">
    <img class="img_05" src="~/images/baicglobal/_nuxt/005.KsEu9dks.png" alt="">
    <span data-i18n="offroad.bullet2">In-depth integration of simulation analysis with design and experimental verification;</span>
  </div>
  <div class="text_3 content_text">
    <img class="img_05" src="~/images/baicglobal/_nuxt/005.KsEu9dks.png" alt="">
    <span data-i18n="offroad.bullet3">The integration of the system such as component level, system level, and vehicle level is a comprehensive integration of virtual and reality.</span>
  </div>

  <!-- Engineering hero (right) -->
  <div class="img_07"><img src="~/images/baicglobal/_nuxt/007.BCpIdD6u.png" alt=""></div>

  <!-- Section title 1 -->
  <h3 class="title title_1" data-i18n="offroad.engVerification">Engineering Verification Ability</h3>

  <!-- Engineering composition (img_09 nested inside img_08) -->
  <div class="img_08">
    <img src="~/images/baicglobal/_nuxt/008.Bwps3Tud.png" alt="">
    <img class="img_09" src="~/images/baicglobal/_nuxt/009.DJTwHOKV.png" alt="">
  </div>

  <!-- Engineering bullet text -->
  <div class="text_4 content_text" data-i18n="offroad.engText1">
    Able to test and verify the functions, performance, reliability, durability and environmental adaptability of components, systems and complete vehicles, and have obtained CNAS certification.
  </div>
  <div class="text_5 content_text" data-i18n="offroad.engText2">
    Professional trial production workshop, with complete trial production verification process, can produce 500 trial production, special production and modified prototype cars per year, and the trial production capacity is leading in China.
  </div>
  <div class="text_6 content_text" data-i18n="offroad.engText3">
    The big data intelligent analysis platform has realized the rapid and accurate extraction of valuable information from massive data, and successfully applied it to various processes of vehicle research and development.
  </div>

  <!-- Vehicle Production composition -->
  <div class="img_010">
    <img class="img_10_1" src="~/images/baicglobal/_nuxt/010.Xg6qSDDC.png" alt="">
    <img class="img_012" src="~/images/baicglobal/_nuxt/012.tk4018y-.png" alt="">
  </div>

  <!-- Quote badge -->
  <div class="img_015"><img src="~/images/baicglobal/_nuxt/015.DYTMujap.png" alt=""></div>

  <!-- Section title 2 -->
  <h3 class="title title_2" data-i18n="offroad.vehicleProduction">Vehicle Production Ability</h3>

  <!-- Vehicle Production text -->
  <div class="text_7 content_text" data-i18n="offroad.vehicleProductionDesc">
    The off-road vehicle factory has an overall construction area of 240,000 square meters and an annual production capacity of 100,000 vehicles, and won the &quot;National Green Factory&quot;, &quot;China&apos;s Best Factory Digital Competition Excellence Award&quot;.
  </div>

  <!-- Factory full-width -->
  <div class="img_011"><img src="~/images/baicglobal/_nuxt/011.LXOGrKhQ.png" alt=""></div>

  <!-- Black panel: title_3 + text_8 + 014 mirror + 013 jpg -->
  <div class="img_013">
    <h3 class="title title_3" data-i18n="offroad.highReliability">High Designed Reliability</h3>
    <div class="text_8 content_text" data-i18n="offroad.highReliabilityDesc">
      It has also created 28 limit and typical working condition load spectrum analysis and extraction methods combining dynamic and static loads, invented 35 high-reliability structures such as opening and closing parts structure, whole vehicle locking system, established virtual and physical tests combined with the multi-level test platform and method, realized the positive design of high reliability of off-road vehicles. The average mileage between failures of BAIC off-road vehicle base test has been increased from 1,200 km to 7,536 km, well above the international level of similar products.
    </div>
    <img class="img_014" src="~/images/baicglobal/_nuxt/011.LXOGrKhQ.png" alt="">
    <img class="img_013_1" src="~/images/baicglobal/_nuxt/013.ByrQoel1.jpg" alt="">
  </div>
</section>

<!-- HISTORY TIMELINE -->
<section class="or-timeline">
  <div class="tl-container">
    <button class="tl-arrow tl-prev" aria-label="Previous" onclick="tlNav(-1)">&#10094;</button>
    <button class="tl-arrow tl-next" aria-label="Next" onclick="tlNav(1)">&#10095;</button>

    <div class="tl-image-wrap">
      <img id="tlImage" src="~/images/baicglobal/file/public/static/offRoad/assets/pc/01.jpg" alt="">
    </div>

    <div class="tl-years" id="tlYears">
      <button class="tl-year-btn active" data-idx="0">1960-1963</button>
      <button class="tl-year-btn" data-idx="1">1966</button>
      <button class="tl-year-btn" data-idx="2">1974</button>
      <button class="tl-year-btn" data-idx="3">1999</button>
      <button class="tl-year-btn" data-idx="4">2002</button>
      <button class="tl-year-btn" data-idx="5">2008</button>
      <button class="tl-year-btn" data-idx="6">2009</button>
      <button class="tl-year-btn" data-idx="7">2013</button>
      <button class="tl-year-btn" data-idx="8">2015</button>
      <button class="tl-year-btn" data-idx="9">2020</button>
      <button class="tl-year-btn" data-idx="10">2025</button>
      <button class="tl-year-btn" data-idx="11" data-i18n="offroad.today">Today</button>
    </div>

    <div class="tl-desc" id="tlDesc"></div>
  </div>
</section>

@section Scripts {
<script>
// Scroll-triggered reveal — fade/slide elements as they enter viewport
(function(){
  const targets = document.querySelectorAll('.or-canvas > *');
  if (targets.length === 0) return;
  if (!('IntersectionObserver' in window)) {
    targets.forEach(el => el.classList.add('is-visible'));
    return;
  }
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0, rootMargin: '0px 0px -8% 0px' });
  targets.forEach(el => io.observe(el));
  // Fallback: reveal anything still hidden once the user has scrolled past it
  // (covers the case where rapid scroll outpaces the observer or print/screenshot tools)
  window.addEventListener('load', () => {
    setTimeout(() => {
      targets.forEach(el => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight) el.classList.add('is-visible');
      });
    }, 60);
  });
})();

const tlKeys = ['1960','1966','1974','1999','2002','2008','2009','2013','2015','2020','2025','today'];

const tlImages = [
  '/images/baicglobal/file/public/static/offRoad/assets/pc/01.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/02.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/03.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/04.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/05.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/06.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/07.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/08.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/09.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/010.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/010.jpg',
  '/images/baicglobal/file/public/static/offRoad/assets/pc/010.jpg'
];

const tlTextsEn = [
  `In December 1960, the Headquarters of the General Staff reported to the State Council, proposing the production of the off-road vehicle (ORV) at the BAW. From 1961, BAW successively developed off-road vehicle models such as BJ210, BJ211, and BJ212. In March 1963, the BJ210C light off-road vehicle passed the technical appraisal organized by the First Ministry of Machine Industry of the PRC and was named the "Beijing" brand.`,
  `In 1966, Chairman Mao inspected the masses at Tian'anmen Square riding in a BJ212. The BJ212 light off-road vehicle officially entered production and service in the same year. The globally renowned BJ212 series, spanning half a century, achieved an industry myth with an accumulated production of over 1.2 million vehicles (including BJ2020).`,
  `The BJ212 produced in 1974 became the first donated collection at the Beijing Auto Museum. The Beijing Jeep BJ212 also carries memories of the 1980s.`,
  `On October 1, 1999, during the 50th National Day Parade, the "BJ2020S" off-road vehicle took the lead and underwent inspection.`,
  `In September 2002, the Central Military Commission issued the development task for the second generation 0.5-ton off-road vehicle, named "Warrior."`,
  `In 2008, BAIC Group initiated the development of the BJ40, its first civilian off-road vehicle.`,
  `On October 1, 2009, during the 60th National Day Parade, "Beijing Warrior" served as the leading and cannon-towing vehicle, undergoing inspection. In the same year, "Warrior" won the first prize in the Chinese automotive industry's technological progress; the development of the Beijing Warrior Improved Model BJ80 began.`,
  `In 2013, the modern BAIC off-road vehicle production base was established, and the professional BAIC off-road vehicle R&D team was officially formed. The first civilian off-road vehicle, "BJ40," was launched at the Water Cube.`,
  `In September 2015, during the "Parade in Commemoration of the 70th Anniversary of the Victory of the Chinese People's War of Resistance Against Japanese Aggression and World Anti-Fascist War," BJ40 was selected as the exclusive designated vehicle for the parade's cannon towing. At the end of the year, after completing 581 cumulative reliability tests covering the entire region (with a total mileage of 2.77 million kilometers), all weather conditions, and all road conditions, the improved Warrior BJ80 was officially put into production and successfully deployed.`,
  `In 2020, BAIC continued to expand its off-road vehicle line-up and global presence, strengthening export markets across the Middle East, Africa, and Latin America.`,
  `In 2025, BAIC unveiled new off-road platforms with advanced electrification options, building on five decades of off-road heritage.`,
  `Originating from the battlefield, and reaching into daily life, Beijing Off-Road maintains the original intention and glory passed down from BJ212, adhering to the ultimate ORV quality. With high-reliability standards designed for challenging conditions on the test field, the average failure interval mileage is 4500 kilometers. The high-reliability indicators help users improve efficiency and reduce costs.`
];

function getTlText(idx) {
  const lang = (window.baicTranslations && window.baicTranslations.getCurrentLang()) || 'en';
  if (lang === 'ar' && window.baicTranslations) {
    const arKey = 'offroad.timeline.' + tlKeys[idx];
    const ar = window.baicTranslations.translations[arKey];
    if (ar) return ar;
  }
  return tlTextsEn[idx];
}

let currentTlIdx = 0;
function setActiveTimeline(idx) {
  if (idx < 0) idx = tlKeys.length - 1;
  if (idx >= tlKeys.length) idx = 0;
  currentTlIdx = idx;
  document.querySelectorAll('.tl-year-btn').forEach(b => {
    b.classList.toggle('active', parseInt(b.dataset.idx) === idx);
  });
  const tlImage = document.getElementById('tlImage');
  if (tlImage && tlImages[idx]) tlImage.src = tlImages[idx];
  document.getElementById('tlDesc').innerHTML = `<p>${getTlText(idx)}</p>`;
  const activeBtn = document.querySelector(`.tl-year-btn[data-idx="${idx}"]`);
  if (activeBtn) activeBtn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
}

function tlNav(delta) {
  setActiveTimeline(currentTlIdx + delta);
}

document.querySelectorAll('.tl-year-btn').forEach(btn => {
  btn.addEventListener('click', () => setActiveTimeline(parseInt(btn.dataset.idx)));
});
document.querySelectorAll('.tl-card').forEach(card => {
  card.addEventListener('click', () => setActiveTimeline(parseInt(card.dataset.idx)));
});

// Re-render description whenever the page language changes — observe <html lang>
new MutationObserver(() => setActiveTimeline(currentTlIdx))
  .observe(document.documentElement, { attributes: true, attributeFilter: ['lang','dir'] });

// Initial load: if Arabic is the stored language, render Arabic description now
if (window.baicTranslations && window.baicTranslations.getCurrentLang() === 'ar') {
  setActiveTimeline(0);
}
</script>
}
