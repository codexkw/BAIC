@{
    ViewData["Title"] = "Capital Beauty";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/capital-beauty.css" asp-append-version="true" />
}

<!-- 1. HERO BANNER -->
<section class="cb-hero">
  <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/banner.jpg" alt="Capital Beauty">
  <div class="cb-hero-overlay"></div>
  <div class="cb-hero-text">
    <h1 data-i18n="capitalBeauty.heroHeading"><strong>CAPITAL</strong> BEAUTY<br>REDEFINED</h1>
    <hr>
    <div class="plus">+</div>
  </div>
</section>

<!-- 2. INTRO: Zhang portrait + text -->
<section class="cb-intro fade-in">
  <div class="cb-intro-img">
    <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/zhang.png" alt="Designer">
  </div>
  <div class="cb-intro-text">
    <p data-i18n="capitalBeauty.intro">As the CAPITAL of China, Beijing is the unity of<br>tradition and modernity, conveys the<br>temperament of order, firmness and<br>trustworthiness, and represents the confidence,<br>glory and dream of Chinese culture.</p>
  </div>
</section>

<!-- 3. FOUR BJ - Glory / Dream -->
<section class="cb-four fade-in">
  <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/four_bj.jpg" alt="Four BJ">
  <div class="cb-four-overlay">
    <div class="cb-four-word"><h2 data-i18n="capitalBeauty.glory">Glory</h2></div>
    <div class="cb-four-word"><h2 data-i18n="capitalBeauty.dream">Dream</h2></div>
  </div>
</section>

<!-- 4. KEYWORDS -->
<section class="cb-keywords fade-in">
  <h3 data-i18n="capitalBeauty.keywordsHeading">CAPITAL BEAUTY: KEYWORDS OF THE DESIGN<br>CONCEPT ARE...</h3>
</section>

<!-- 5. THREE IMAGE: Confidence / Warmth / Oriental Style -->
<section class="cb-three fade-in">
  <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/three_image.jpg" alt="Design Concepts">
  <div class="cb-three-overlay">
    <div class="cb-three-items">
      <div class="cb-three-item">
        <h4 data-i18n="capitalBeauty.confidence">Confidence</h4>
        <p>Peaceful, calm, simple<br>but not shallow</p>
      </div>
      <div class="cb-three-item">
        <h4 data-i18n="capitalBeauty.warmth">Warmth</h4>
        <p>Friendly, practical, comfortable<br>but not exaggerated</p>
      </div>
      <div class="cb-three-item">
        <h4 data-i18n="capitalBeauty.orientalStyle">Oriental Style</h4>
        <p>Unique,aesthetic,stylish<br>but not conservative</p>
      </div>
    </div>
  </div>
</section>

<!-- 6. COLOUR AESTHETICS OF CAPITAL BEAUTY (each word on its own line) -->
<section class="cb-colour fade-in">
  <div class="cb-colour-title" data-i18n="capitalBeauty.colourAesthetics">
    <span>COLOUR</span>
    <span>AESTHETICS</span>
    <span class="small">OF</span>
    <span>CAPITAL</span>
    <span>BEAUTY</span>
  </div>
  <div class="cb-colour-grid">
    <a href="#"><img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/gugong1.jpg" alt="Palace colours"></a>
    <a href="#"><img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/white_jade.jpg" alt="White jade"></a>
  </div>
</section>

<!-- 7. CHINA INK: "leaving blank" + MODERN SIMPLICITY (single section, image left, text right) -->
<section class="cb-ink fade-in">
  <div class="cb-ink-img">
    <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/china_ink.jpg" alt="Chinese ink">
  </div>
  <div class="cb-ink-text">
    <div class="cb-ink-quote">
      <p>The essence of<br><br><em>"leaving<br>blank"</em><br><br>expands new<br>reverie</p>
    </div>
    <div class="cb-ink-modern">
      <h3 data-i18n="capitalBeauty.modernSimplicity">MODERN<br>SIMPLICITY</h3>
      <p>If one word can be used to describe the biggest feature of ancient Chinese painting and calligraphy culture, it must be BLANK. It can be said that the white space is the essence of the Chinese art form, a unique Oriental and very special artistic expression technique.</p>
    </div>
  </div>
</section>

<!-- 8. WARM EXPERIENCE (blue car, text on right) -->
<section class="cb-warm fade-in">
  <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/bluecar.jpg" alt="Blue car">
  <div class="cb-warm-overlay">
    <h3 data-i18n="capitalBeauty.warmExperience">WARM<br>EXPERIENCE</h3>
    <p>"Purity of Confidence" and "Warm Wisdom" are the design concepts of BAIC Group's BEIJING brand. Whether it is exterior design or interior design, from the perspective of users, experience a feeling of unlimited freedom, bring positive feelings to future users, and convey the maturity and confidence of brand design from the emotional value.</p>
  </div>
</section>

<!-- 9. MEETING -->
<section class="cb-fullimg fade-in">
  <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/meeting.jpg" alt="BAIC Meeting">
</section>

<!-- 10. FINAL IMAGE -->
<section class="cb-fullimg fade-in">
  <img src="~/images/baicglobal/file/public/static/topic/2023-capital-beauty-redefined/images/four_bg2.jpg" alt="BAIC Capital Beauty">
</section>

@section Scripts {
}
