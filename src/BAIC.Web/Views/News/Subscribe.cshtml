@{
    ViewData["Title"] = "Subscribe";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/subscribe.css" asp-append-version="true" />
}

<!-- HERO -->
<section class="sub-hero">
  <img src="https://www.baicglobal.com/_nuxt/banner.CiZCqB0x.avif" alt="Subscribe">
  <div class="sub-hero-overlay"></div>
  <div class="sub-hero-content">
    <h1 data-i18n="subscribe.heroHeading">Subscribe</h1>
    <p data-i18n="subscribe.heroText">Welcome to the News Subscription Center. If you are interested in our news, please keep abreast of us.<br>Your information will be kept strictly confidential and limited to our sending you press releases.</p>
  </div>
</section>

<!-- FORM -->
<div class="sub-form-section">
  <h2 data-i18n="subscribe.alwaysWithYou">BAIC<span>，</span>Always Be With You</h2>

  <div class="sub-row">
    <div class="sub-field">
      <label data-i18n="subscribe.firstName">First Name</label>
      <input type="text" placeholder="" data-i18n="subscribe.firstName">
    </div>
    <div class="sub-field">
      <label data-i18n="subscribe.lastName">Last Name</label>
      <input type="text" placeholder="" data-i18n="subscribe.lastName">
    </div>
  </div>

  <div class="sub-row">
    <div class="sub-field">
      <label data-i18n="subscribe.mediaName">Media Name</label>
      <input type="text" placeholder="" data-i18n="subscribe.mediaName">
    </div>
    <div class="sub-field">
      <label data-i18n="subscribe.email">E-mail</label>
      <input type="email" placeholder="" data-i18n="subscribe.email">
    </div>
  </div>

  <div class="sub-field full" style="margin-bottom:0">
    <label data-i18n="subscribe.mediaIntro">Media Introduction</label>
    <textarea placeholder="" data-i18n="subscribe.mediaIntro"></textarea>
  </div>

  <button class="sub-submit" data-i18n="subscribe.btn">SUBSCRIBE</button>
</div>

@section Scripts {
}
