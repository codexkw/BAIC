@{
    ViewData["Title"] = "Subscribe";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/subscribe.css" asp-append-version="true" />
}

<!-- HERO -->
<section class="sub-hero">
  <img src="https://www.baicglobal.com/_nuxt/banner.CiZCqB0x.avif" alt="Subscribe">
  <div class="sub-hero-overlay"></div>
  <div class="sub-hero-content">
    <h1>Subscribe</h1>
    <p>Welcome to the News Subscription Center. If you are interested in our news, please keep abreast of us.<br>Your information will be kept strictly confidential and limited to our sending you press releases.</p>
  </div>
</section>

<!-- FORM -->
<div class="sub-form-section">
  <h2>BAIC<span>，</span>Always Be With You</h2>

  <div class="sub-row">
    <div class="sub-field">
      <label>First Name</label>
      <input type="text" placeholder="">
    </div>
    <div class="sub-field">
      <label>Last Name</label>
      <input type="text" placeholder="">
    </div>
  </div>

  <div class="sub-row">
    <div class="sub-field">
      <label>Media Name</label>
      <input type="text" placeholder="">
    </div>
    <div class="sub-field">
      <label>E-mail</label>
      <input type="email" placeholder="">
    </div>
  </div>

  <div class="sub-field full" style="margin-bottom:0">
    <label>Media Introduction</label>
    <textarea placeholder=""></textarea>
  </div>

  <button class="sub-submit">SUBSCRIBE</button>
</div>

@section Scripts {
}
