  <!-- Phone -->
  <div class="cu-row">
    <div class="cu-field full">
      <label data-i18n="contactUs.phone">Phone</label>
      <div class="cu-phone-row">
        <div class="cu-phone-code">
          <select>
            <option value="+965" selected>+965</option>
          </select>
        </div>
        <div class="cu-phone-num">
          <input type="tel" placeholder="">
        </div>
      </div>
    </div>
  </div>

  <!-- E-mail -->
  <div class="cu-row">
    <div class="cu-field full">
      <label data-i18n="contactUs.email">E-mail</label>
      <input type="email" data-i18n="contactUs.email">
    </div>
  </div>

  <!-- Problem Type -->
  <div class="cu-row">
    <div class="cu-field full">
      <label data-i18n="contactUs.problemType">Problem Type</label>
      <select>
        <option value="" disabled selected>Please select problem type</option>
        <option data-i18n="contactUs.other">Other</option>
        <option data-i18n="contactUs.product">Product</option>
        <option data-i18n="contactUs.afterSales">After Sales</option>
        <option data-i18n="contactUs.sales">Sales</option>
        <option data-i18n="contactUs.businessCoop">Business Cooperation</option>
        <option data-i18n="contactUs.usedCarSales">used-car sales</option>
      </select>
    </div>
  </div>

  <!-- Questions -->
  <div class="cu-field full">
    <label data-i18n="contactUs.questions">Questions</label>
    <textarea data-i18n="contactUs.questions"></textarea>
  </div>

  <p class="cu-note" data-i18n="contactUs.moreInfo">If you have more information, please send to <a href="mailto:info@@baickuwait.com">info@@baickuwait.com</a></p>

  <button class="cu-submit" data-i18n="contactUs.submit">SUBMIT</button>
</div>

