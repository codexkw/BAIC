@{
    ViewData["Title"] = "Contact Us";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/contact-us.css" asp-append-version="true" />
}

<!-- HERO -->
<section class="cu-hero">
  <img src="https://www.baicglobal.com/_nuxt/banner.Bzzl8AWw.avif" alt="Contact Us">
  <div class="cu-hero-overlay"></div>
  <div class="cu-hero-content">
    <h1 data-i18n="contactUs.heroHeading">Contact Us</h1>
    <p data-i18n="contactUs.heroText">Thank you for your support to BAIC, &nbsp; <br>Please leave your contact information and questions, we will arrange professionals to contact you</p>
  </div>
</section>

<!-- FORM -->
<div class="cu-form">

  <!-- Gender -->
  <div class="cu-row">
    <div class="cu-field full">
      <label data-i18n="contactUs.gender">Gender</label>
      <select>
        <option value="" disabled selected></option>
        <option data-i18n="contactUs.mr">Mr</option>
        <option data-i18n="contactUs.miss">Miss</option>
        <option data-i18n="contactUs.ms">Ms</option>
        <option data-i18n="contactUs.dr">Dr</option>
        <option data-i18n="contactUs.others">others</option>
      </select>
    </div>
  </div>

  <!-- Full Name -->
  <div class="cu-row">
    <div class="cu-field full">
      <label data-i18n="contactUs.fullName">Full Name</label>
      <input type="text" data-i18n="contactUs.fullName">
    </div>
  </div>

  <!-- Nationality -->
  <div class="cu-row">
    <div class="cu-field full">
      <label data-i18n="contactUs.nationality">Nationality</label>
