<!-- FEATURE: EXTERIOR -->
<section class="feature-full" style="min-height:85vh">
  <img src="https://www.baicglobal.com/file/common/image/2023/06/15/pc1_20230615182955A149.png" alt="BJ40 PLUS Exterior">
  <div class="feature-overlay">
    <h3>Commanding Off-Road Presence</h3>
    <p>The BJ40 PLUS combines rugged off-road capability with urban sophistication. Its bold design language with black removable hard ceiling and front/rear red tow hooks make a powerful statement.</p>
  </div>
</section>

<!-- FEATURE: INTERIOR (Side) -->
<section>
  <div class="feature-side">
    <div class="feature-side-img">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/15/2_20230615183050A151.png" alt="Interior">
    </div>
    <div class="feature-side-content">
      <h3>Purposeful Interior</h3>
      <p>12.3-inch LCD instrument cluster paired with a 10-inch infotainment display. The co-pilot illuminated BJ40 logo handle and anti-roll cage reinforce the vehicle's off-road DNA. 220V power outlet in trunk keeps you connected on every adventure.</p>
    </div>
  </div>
</section>

<!-- FEATURE: OFF-ROAD -->
<section class="feature-full" style="min-height:80vh">
  <img src="https://www.baicglobal.com/file/common/image/2023/06/15/3_20230615183142A132.png" alt="Off-road">
  <div class="feature-overlay">
    <h3>Electronic Time-Sharing 4WD</h3>
    <p>Front and rear axle electronically controlled differential locks with lightweight front axle. Snow/Sport mode and Comfort/Economy mode for every driving scenario. 37° approach angle and 31° departure angle conquer the toughest terrain.</p>
  </div>
</section>

<!-- FEATURE: DUO - Tires + Seats -->
<section>
  <div class="feature-duo">
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/15/4_20230615183154A133.png" alt="Detail">
      <div class="feature-duo-ov">
        <h4>AT Tires &amp; 17" Alloy Wheels</h4>
        <p>265/65 R17 all-terrain tires with blackened rims and red calipers</p>
      </div>
    </div>
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/15/5_20230615184234A165.png" alt="Seats">
      <div class="feature-duo-ov">
        <h4>Leather Seats</h4>
        <p>6-way power driver seat with auto lumbar adjust. Rear 4/6 foldable for maximum cargo flexibility.</p>
      </div>
    </div>
  </div>
</section>

<!-- FEATURE: DASHBOARD -->
<section class="feature-full" style="min-height:80vh">
  <img src="https://www.baicglobal.com/file/common/image/2023/06/15/6_20230615183345A155.png" alt="Dashboard">
  <div class="feature-overlay">
    <h3>Dual-Screen Digital Cockpit</h3>
    <p>12.3-inch LCD instrument cluster with 10-inch central infotainment display. Easyconnection mobile connectivity, Bluetooth, AM/FM radio, and external video playback with 6-speaker audio system.</p>
  </div>
</section>

<!-- FEATURE: SAFETY (Side reversed) -->
<section>
  <div class="feature-side" style="direction:rtl">
    <div class="feature-side-img" style="direction:ltr">
      <img src="https://www.baicglobal.com/file/common/image/2024/02/07/7_20240207140748A056.jpg" alt="Safety">
    </div>
    <div class="feature-side-content" style="direction:ltr">
      <h3>Comprehensive Safety</h3>
      <p>ABS+EBD, ESC, EBA, TCA, HAC, HDC, RMI electronic safety suite. Driver and passenger airbags with front three-point seat belts with pretensioner. Engine immobilizer and theft-deterrent system for complete peace of mind.</p>
    </div>
  </div>
</section>

<!-- FEATURE: DUO - Atmosphere + Frame -->
<section>
  <div class="feature-duo">
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/15/8_20230615183602A158.png" alt="Atmosphere">
      <div class="feature-duo-ov">
        <h4>Ambient Atmosphere</h4>
        <p>Double cup holder ribbon lamp, interior point and ribbon atmosphere lamps</p>
      </div>
    </div>
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2022/08/11/9_20220811115631A050.jpg" alt="Capability">
      <div class="feature-duo-ov">
        <h4>Separate Frame Construction</h4>
        <p>Double boom/helical spring front independent suspension with five-bar rear</p>
      </div>
    </div>
  </div>
</section>

