@{
    ViewData["Title"] = "BJ40 PLUS";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/bj40plus.css" asp-append-version="true" />
}

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"><img src="https://www.baicglobal.com/file/common/image/2023/06/15/pc1_20230615182955A149.png" alt="BJ40 PLUS"></div>
  <div class="hero-content">
    <div class="hero-sub">Well Balance Between City And Wildness</div>
    <h1>BJ40 PLUS</h1>
    <div class="hero-tag">All Terrain Adoption, High Load-Carrying, Part-Time 4WD System</div>
    <a href="#testdrive" class="hero-btn" data-i18n="model.testDrive">Test Drive</a>
  </div>
</section>

