<!-- FEATURE: EXTERIOR -->
<section class="feature-full" style="min-height:85vh">
  <img src="https://www.baicglobal.com/file/common/image/2025/06/13/pc1_20240719171451A079_20250613152822A343.webp" alt="BJ40 PLUS RHD">
  <div class="feature-overlay">
    <h3>Right Hand Drive Off-Road Excellence</h3>
    <p>The BJ40 PLUS RHD brings BAIC's legendary off-road capability to right-hand drive markets. Separate frame construction with electronic time-sharing 4WD conquers any terrain.</p>
  </div>
</section>

<!-- FEATURE: INTERIOR (Side) -->
<section>
  <div class="feature-side">
    <div class="feature-side-img">
      <img src="https://www.baicglobal.com/file/common/image/2025/06/13/2_20240719171513A080_20250613151004A332.webp" alt="Interior">
    </div>
    <div class="feature-side-content">
      <h3>RHD Cockpit</h3>
      <p>12.3-inch LCD instrument cluster paired with a 10-inch infotainment display. Easyconnection mobile connectivity with Bluetooth telephone and music. Anti-roll cage reinforces the vehicle's rugged off-road DNA.</p>
    </div>
  </div>
</section>

<!-- FEATURE: OFF-ROAD -->
<section class="feature-full" style="min-height:80vh">
  <img src="https://www.baicglobal.com/file/common/image/2025/06/13/3_20240719171558A085_20250613151101A335.webp" alt="Off-road">
  <div class="feature-overlay">
    <h3>Electronic Time-Sharing 4WD</h3>
    <p>Rear axle electronically controlled differential lock with optional front axle lock and lightweight front axle. Snow/Sport and Comfort/Economy driving modes for every scenario. 37° approach angle and 31° departure angle.</p>
  </div>
</section>

<!-- FEATURE: DUO - Tires + Seats -->
<section>
  <div class="feature-duo">
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2025/06/13/4_20240719171608A086_20250613153221A353.webp" alt="Detail">
      <div class="feature-duo-ov">
        <h4>AT Tires &amp; 17" Alloy Wheels</h4>
        <p>265/65 R17 all-terrain tires with double color alloy rims</p>
      </div>
    </div>
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2025/06/13/5_20240719171646A091_20250613153151A350.webp" alt="Seats">
      <div class="feature-duo-ov">
        <h4>Leather Seats</h4>
        <p>6-way power driver and passenger seats with auto lumbar adjust. Rear 4/6 foldable seats.</p>
      </div>
    </div>
  </div>
</section>

<!-- FEATURE: DASHBOARD -->
<section class="feature-full" style="min-height:80vh">
  <img src="https://www.baicglobal.com/file/common/image/2025/06/13/6_20240719171659A092_20250613153112A348.webp" alt="Dashboard">
  <div class="feature-overlay">
    <h3>Dual-Screen Digital Cockpit</h3>
    <p>12.3-inch LCD instrument cluster with 10-inch central infotainment. LED front combination headlights, daytime running lights, and atmosphere lighting throughout the cabin create an immersive driving experience.</p>
  </div>
</section>

<!-- FEATURE: SAFETY (Side reversed) -->
<section>
  <div class="feature-side" style="direction:rtl">
    <div class="feature-side-img" style="direction:ltr">
      <img src="https://www.baicglobal.com/file/common/image/2024/07/08/29_20240708144139A101.jpg" alt="Safety">
    </div>
    <div class="feature-side-content" style="direction:ltr">
      <h3>Comprehensive Safety</h3>
      <p>ABS+EBD, ESC, EBA, TCA, HAC, HDC, RMI electronic safety systems. Driver and passenger airbags with front three-point pretensioner seat belts. EPB with auto-hold, parking sensor, and reversing video system for confidence in any situation.</p>
    </div>
  </div>
</section>

<!-- FEATURE: DUO - Atmosphere + Frame -->
<section>
  <div class="feature-duo">
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2025/06/13/8_20240719171835A097_20250613151234A339.webp" alt="Atmosphere">
      <div class="feature-duo-ov">
        <h4>Ambient Atmosphere</h4>
        <p>Double cup holder ribbon lamp, interior point atmosphere lamp, foot space lighting</p>
      </div>
    </div>
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2025/06/13/9_20240719171858A098_20250613151259A340.webp" alt="Frame">
      <div class="feature-duo-ov">
        <h4>Separate Frame Construction</h4>
        <p>Double boom/helical spring front independent suspension with five-bar rear</p>
      </div>
    </div>
  </div>
</section>

