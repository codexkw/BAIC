<!-- TEST DRIVE -->
<section class="testdrive" id="testdrive">
  <div class="testdrive-bg"><img src="https://www.baicglobal.com/file/common/image/2025/06/13/pc1_20240719171451A079_20250613152822A343.webp" alt=""></div>
  <div class="testdrive-inner">
    <h3>APPOINTMENT FOR A TEST DRIVE</h3>
    <p>Book your test drive experience</p>
    <div class="form-row">
      <select class="form-input">
        <option value="">Please select Gender</option>
        <option>Mr</option>
        <option>Miss</option>
        <option>Ms</option>
        <option>Dr</option>
      </select>
      <input class="form-input" type="text" placeholder="First Name">
      <input class="form-input" type="text" placeholder="Last Name">
    </div>
    <div class="form-row">
      <select class="form-input" style="flex:0 0 100px">
        <option>+86</option>
        <option>+966</option>
        <option>+971</option>
        <option>+965</option>
        <option>+1</option>
        <option>+44</option>
      </select>
      <input class="form-input" type="tel" placeholder="Phone Number">
    </div>
    <div class="form-row">
      <input class="form-input" type="email" placeholder="Email">
    </div>
    <button class="form-submit">SUBMIT</button>
  </div>
</section>

@section Scripts {
<script>
// Color thumbnails
document.querySelectorAll('.color-thumb').forEach(thumb => {
  thumb.addEventListener('click', () => {
    document.querySelectorAll('.color-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
    const img = document.getElementById('mainCarImg');
    img.style.opacity = '0.3';
    setTimeout(() => { img.src = thumb.dataset.src; img.style.opacity = '1'; }, 200);
  });
});
</script>
}
