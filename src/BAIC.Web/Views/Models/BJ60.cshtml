@{
    ViewData["Title"] = "BJ60";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/bj60.css" asp-append-version="true" />
}

<!-- HERO KV -->
<section class="hero-kv">
  <img class="kv-bg" src="~/images/baicglobal/file/public/static/bj60/images/kv1.jpg" alt="BAIC BJ60 KV">
  <div class="hero-kv-overlay">
    <div class="hero-kv-text">
      <img src="~/images/baicglobal/file/public/static/bj60/images/text.png" alt="BJ60">
    </div>
    <div class="hero-btns">
      <a href="#testdrive" class="hero-btn" data-i18n="model.testDrive">Test Drive</a>
      <a href="https://www.baicglobal.com/vrbj60/" class="hero-btn vr" target="_blank" data-i18n="model.viewVR">View VR</a>
    </div>
  </div>
</section>

<!-- VIDEO -->
<section class="video-section">
  <img src="~/images/baicglobal/file/public/static/bj60/images/cover.jpg" alt="BJ60 Video">
  <div class="play-btn"></div>
</section>

<!-- COLOR GALLERY -->
<section class="color-section">
  <div class="color-car">
    <img id="mainCarImg" src="~/images/baicglobal/file/public/static/bj60/images/car_05.png" alt="BJ60">
  </div>
  <div class="color-thumbs" id="colorThumbs">
    <div class="color-thumb active" data-src="~/images/baicglobal/file/public/static/bj60/images/car_05.png"><img src="~/images/baicglobal/file/public/static/bj60/images/car_05.png" alt="View 1"></div>
    <div class="color-thumb" data-src="~/images/baicglobal/file/public/static/bj60/images/car_02.png"><img src="~/images/baicglobal/file/public/static/bj60/images/car_02.png" alt="View 2"></div>
    <div class="color-thumb" data-src="~/images/baicglobal/file/public/static/bj60/images/car_03.png"><img src="~/images/baicglobal/file/public/static/bj60/images/car_03.png" alt="View 3"></div>
    <div class="color-thumb" data-src="~/images/baicglobal/file/public/static/bj60/images/car_04.png"><img src="~/images/baicglobal/file/public/static/bj60/images/car_04.png" alt="View 4"></div>
    <div class="color-thumb" data-src="~/images/baicglobal/file/public/static/bj60/images/car_07.png"><img src="~/images/baicglobal/file/public/static/bj60/images/car_07.png" alt="View 5"></div>
    <div class="color-thumb" data-src="~/images/baicglobal/file/public/static/bj60/images/car_06.png"><img src="~/images/baicglobal/file/public/static/bj60/images/car_06.png" alt="View 6"></div>
  </div>
</section>

<!-- DETAIL GALLERY -->
<section class="detail-gallery">
  <a href="#"><img src="~/images/baicglobal/file/public/static/bj60/images/img_04.jpg" alt="BJ60"></a>
  <a href="#"><img src="~/images/baicglobal/file/public/static/bj60/images/img_05.jpg" alt="BJ60"></a>
  <a href="#"><img src="~/images/baicglobal/file/public/static/bj60/images/img_06.jpg" alt="BJ60"></a>
  <a href="#"><img src="~/images/baicglobal/file/public/static/bj60/images/img_02.jpg" alt="BJ60"></a>
  <a href="#"><img src="~/images/baicglobal/file/public/static/bj60/images/img_01.jpg" alt="BJ60"></a>
  <a href="#"><img src="~/images/baicglobal/file/public/static/bj60/images/img_03.jpg" alt="BJ60"></a>
</section>

<!-- SPECS STRIP -->
<section class="specs-strip">
  <div class="specs-strip-inner">
    <div class="spec-item"><div class="spec-value">196 <sub>KW</sub></div><div class="spec-label" data-i18n="model.maxPower">POWER</div></div>
    <div class="spec-item"><div class="spec-value">406 <sub>N·M</sub></div><div class="spec-label" data-i18n="model.maxTorque">TORQUE</div></div>
    <div class="spec-item"><div class="spec-value">2.0 <sub>T</sub></div><div class="spec-label" data-i18n="model.engine">ENGINE</div></div>
    <div class="spec-item"><div class="spec-value">9.70 <sub>L</sub></div><div class="spec-label" data-i18n="model.fuelConsumption">NEDC</div></div>
    <div class="spec-item"><div class="spec-value">2820 <sub>MM</sub></div><div class="spec-label" data-i18n="model.wheelbase">WHEELBASE</div></div>
  </div>
</section>

<!-- Parameter image -->
<section class="feature-full" style="min-height:70vh">
  <img src="~/images/baicglobal/file/public/static/bj60/images/parameter.jpg" alt="BJ60 Parameters">
</section>

<!-- HIGHLIGHT 1: EXTERIOR -->
<section class="highlight">
  <div class="hl-block" id="hl1">
    <div class="hl-main">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_1_1.jpg" alt="Wheel Hub" class="active" data-idx="0">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_1_2.jpg" alt="LED Taillights" data-idx="1">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_1_3.jpg" alt="Brake Light" data-idx="2">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_1_4.jpg" alt="Grille Light" data-idx="3">
    </div>
    <div class="hl-tabs">
      <div class="hl-tab active" data-idx="0"><h4 data-i18n="bj60.hl1aTitle">Wheel Hub</h4><p data-i18n="bj60.hl1aDesc">18-inch, 20-inch oversized wheels.</p></div>
      <div class="hl-tab" data-idx="1"><h4 data-i18n="bj60.hl1bTitle">LED Taillights</h4><p data-i18n="bj60.hl1bDesc">When lit, an abstract lantern pattern appears on the inner upper and lower brake light cover.</p></div>
      <div class="hl-tab" data-idx="2"><h4 data-i18n="bj60.hl1cTitle">Brake Light</h4><p data-i18n="bj60.hl1cDesc">The inspiration comes from the Great Wall arrow buttress.</p></div>
      <div class="hl-tab" data-idx="3"><h4 data-i18n="bj60.hl1dTitle">Grille Light</h4><p data-i18n="bj60.hl1dDesc">The "five-hole" grille lamp is the core embodiment of the lighting design, inheriting the elements of the five-square hole of BAIC off-road vehicles families.</p></div>
    </div>
  </div>
</section>

<!-- HIGHLIGHT 2: INTERIOR -->
<section class="highlight">
  <div class="hl-block" id="hl2">
    <div class="hl-main">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_kv_1.jpg" alt="Interior" class="active" data-idx="0">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_2_3.jpg" alt="Panoramic Sunroof" data-idx="1">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_2_1.jpg" alt="Four-screen linkage" data-idx="2">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_2_2.jpg" alt="Large Space" data-idx="3">
    </div>
    <div class="hl-tabs">
      <div class="hl-tab active" data-idx="0"><h4 data-i18n="bj60.hl2aTitle">Interior</h4><p data-i18n="bj60.hl2aDesc">The Infinity theatre-grade luxury sound system along with the luxurious and comfortable first-class seats, provides an experience of indulgent comfort.</p></div>
      <div class="hl-tab" data-idx="1"><h4 data-i18n="bj60.hl2bTitle">Panoramic Sunroof</h4><p data-i18n="bj60.hl2bDesc">The full range comes standard with a transparent panoramic skylight of 0.82m².</p></div>
      <div class="hl-tab" data-idx="2"><h4 data-i18n="bj60.hl2cTitle">Four-screen linkage</h4><p data-i18n="bj60.hl2cDesc">Off-road features W-HUD head-up display, more suitable for off-road scenarios, imaging distance up to 2.2m.</p></div>
      <div class="hl-tab" data-idx="3"><h4 data-i18n="bj60.hl2dTitle">Large Space</h4><p data-i18n="bj60.hl2dDesc">7/5 seats for diverse needs, with a third row of easy access (7 seats).</p></div>
    </div>
  </div>
</section>

<!-- HIGHLIGHT 3: PERFORMANCE -->
<section class="highlight">
  <div class="hl-block" id="hl3">
    <div class="hl-main">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_kv_2.jpg" alt="Performance" class="active" data-idx="0">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_3_3.jpg" alt="Tires" data-idx="1">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_3_1.jpg" alt="Differential Locks" data-idx="2">
      <img src="~/images/baicglobal/file/public/static/bj60/images/high_3_2.jpg" alt="Intelligent Control" data-idx="3">
    </div>
    <div class="hl-tabs">
      <div class="hl-tab active" data-idx="0"><h4 data-i18n="bj60.hl3aTitle">Performance</h4><p data-i18n="bj60.hl3aDesc">Based on the characteristics of different terrains, different modes can be selected through the all-terrain knob and transfer knob.</p></div>
      <div class="hl-tab" data-idx="1"><h4 data-i18n="bj60.hl3bTitle">Tires</h4><p data-i18n="bj60.hl3bDesc">AT tread all-terrain tires (optional, 265/65R18-AT 275/50 R20-HT).</p></div>
      <div class="hl-tab" data-idx="2"><h4 data-i18n="bj60.hl3cTitle">Three Differential Locks</h4><p data-i18n="bj60.hl3cDesc">Center differential lock, Front differential lock, Rear differential lock. Crawl Control System under 1-12km/h. Part Time 4WD with 2H, 4H, 4L.</p></div>
      <div class="hl-tab" data-idx="3"><h4 data-i18n="bj60.hl3dTitle">Global Intelligent Control System</h4><p data-i18n="bj60.hl3dDesc">It has 9 driving modes and 17 driving combinations.</p></div>
    </div>
  </div>
</section>

<!-- ENGINE SECTION -->
<section class="feature-full" style="min-height:75vh">
  <img src="~/images/baicglobal/file/public/static/bj60/images/high_4_1.jpg" alt="BJ60 Engine">
  <div class="feature-overlay">
    <h3 data-i18n="bj60.engineTitle">ENGINE</h3>
    <p data-i18n="bj60.engineDesc">2.0T turbocharged engine delivering 196kW of power and 406N·m of torque, paired with an advanced transmission system for exceptional performance both on and off road.</p>
  </div>
</section>

<!-- 360° / ADAS SECTION -->
<section class="feature-side">
  <div class="feature-side-img">
    <img src="~/images/baicglobal/file/public/static/bj60/images/high_4_2.jpg" alt="360° Panoramic">
  </div>
  <div class="feature-side-content">
    <h3 data-i18n="bj60.panoramicTitle">360° Panoramic System</h3>
    <p><strong data-i18n="bj60.panoramicImagingLabel">360° PANORAMIC IMAGING:</strong><br><span data-i18n="bj60.panoramicImagingDesc">Four million pixels high-definition cameras, using high-definition image stitching technology, visually view the information around the vehicle.</span></p>
    <br>
    <p><strong data-i18n="bj60.godsPerspectiveLabel">GOD'S PERSPECTIVE:</strong><br><span data-i18n="bj60.godsPerspectiveDesc">Supports a god's eye view to oversee the entire surroundings, providing a more reassuring driving experience.</span></p>
    <br>
    <p><strong data-i18n="bj60.transparentChassisLabel">180° TRANSPARENT CHASSIS:</strong><br><span data-i18n="bj60.transparentChassisDesc">Through the vehicle's system, it can accurately display the blind spot information below the chassis, reducing the blind spots in the chassis while driving.</span></p>
    <br>
    <p><strong data-i18n="bj60.automatedParkingLabel">AUTOMATED PARKING:</strong><br><span data-i18n="bj60.automatedParkingDesc">A single click initiates automatic parking within the vehicle.</span></p>
  </div>
</section>

<!-- ADAS -->
<section class="feature-full" style="min-height:70vh">
  <img src="~/images/baicglobal/file/public/static/bj60/images/high_4_3.jpg" alt="ADAS">
  <div class="feature-overlay">
    <h3 data-i18n="bj60.adasTitle">Advanced Intelligent Assisted Driving</h3>
    <p data-i18n="bj60.adasDesc">Door opening warning · Active emergency braking · Reverse lateral warning · Full Speed Domain Adaptive Cruise Control · Traffic signs · Front collision warning · Lane center hold</p>
  </div>
</section>

<!-- PARAMETERS -->
<section class="params">
  <div class="params-bg">
    <img src="~/images/baicglobal/file/public/static/bj60/images/config_bg.jpg" alt="">
  </div>
  <div class="params-inner">
    <h4 data-i18n="model.configuration">configuration</h4>
    <h2><strong>BJ60</strong> <span data-i18n="model.parameters">PARAMETER</span></h2>
    <div class="param-grid">
      <div class="param-cell"><div class="p-label" data-i18n="model.dimensions">Length x Width x Height (mm)</div><div class="p-val">5040 x 1955 x 1925</div></div>
      <div class="param-cell"><div class="p-label" data-i18n="model.wheelbase">Wheelbase (mm)</div><div class="p-val">2820</div></div>
      <div class="param-cell"><div class="p-label" data-i18n="model.engine">Engine</div><div class="p-val">2.0T</div></div>
      <div class="param-cell"><div class="p-label" data-i18n="model.maxPower">Rated power (kw)</div><div class="p-val">196</div></div>
      <div class="param-cell" style="grid-column:span 2"><div class="p-label" data-i18n="model.maxTorque">Max. torque (N·m)</div><div class="p-val">406</div></div>
    </div>
    <a href="#" class="param-link" data-i18n="model.detailedParams">DETAILED PARAMETERS ↓</a>
    <p class="params-note" data-i18n="model.specsDisclaimer">Note: All information content is for advertising display purposes only and is for reference. The actual vehicle shall prevail. BAIC reserves the right to modify the described vehicle models and is not obligated to provide prior notice for the purposes of marketing or product promotion at any time.</p>
  </div>
</section>

<!-- TEST DRIVE -->
<section class="testdrive" id="testdrive">
  <div class="testdrive-inner">
    <h3 data-i18n="model.testDrive">APPOINTMENT FOR A TEST DRIVE</h3>
    <p data-i18n="model.bookTestDrive">Book your test drive experience</p>
    <a asp-controller="Models" asp-action="TestDrive" asp-route-model="BJ60" class="testdrive-link" data-i18n="testDrive.bookNow">BOOK A TEST DRIVE</a>
  </div>
</section>

@section Scripts {
<script>
// Color thumbnails
document.querySelectorAll('.color-thumb').forEach(thumb => {
  thumb.addEventListener('click', () => {
    document.querySelectorAll('.color-thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
    const img = document.getElementById('mainCarImg');
    img.style.opacity = '0.3';
    setTimeout(() => { img.src = thumb.dataset.src; img.style.opacity = '1'; }, 200);
  });
});

// Highlight tabbed sections
document.querySelectorAll('.hl-block').forEach(block => {
  const imgs = block.querySelectorAll('.hl-main img');
  const tabs = block.querySelectorAll('.hl-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      imgs.forEach(i => i.classList.remove('active'));
      tab.classList.add('active');
      imgs[tab.dataset.idx].classList.add('active');
    });
  });
});
</script>
}
