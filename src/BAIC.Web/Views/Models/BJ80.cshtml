@{
    ViewData["Title"] = "BJ80";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/bj80.css" asp-append-version="true" />
}

<!-- HERO -->
<section class="hero">
  <div class="hero-bg">
    <img src="https://www.baicglobal.com/file/common/image/2023/06/19/pc5_20230619105543A205.jpg" alt="BJ80">
  </div>
  <div class="hero-content">
    <div class="hero-subtitle" data-i18n="bj80.heroSubtitle">Galaxy Flagship, Glorious Shinning Trip</div>
    <h1 class="hero-title">BJ80</h1>
    <div class="hero-tagline" data-i18n="bj80.heroTagline">Reveal Off-Road Nature, Thorough Guarantee, Military Grade</div>
    <a href="#testdrive" class="hero-btn" data-i18n="model.testDrive">Test Drive</a>
  </div>
</section>

<!-- COLOR GALLERY -->
<section class="color-gallery">
  <div class="color-car">
    <img id="mainCarImg" src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_001_20241216154837A655.png" alt="BJ80">
  </div>
  <div class="color-thumbs" id="colorThumbs">
    <div class="color-thumb active" data-src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_001_20241216154837A655.png"><img src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_001_20241216154837A655.png" alt="View 1"></div>
    <div class="color-thumb" data-src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_002_20241216154857A656.png"><img src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_002_20241216154857A656.png" alt="View 2"></div>
    <div class="color-thumb" data-src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_003_20241216154911A657.png"><img src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_003_20241216154911A657.png" alt="View 3"></div>
    <div class="color-thumb" data-src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_004_20241216154918A658.png"><img src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_004_20241216154918A658.png" alt="View 4"></div>
    <div class="color-thumb" data-src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_005_20241216154924A659.png"><img src="https://www.baicglobal.com/file/common/image/2024/12/16/DM_20241216154225_005_20241216154924A659.png" alt="View 5"></div>
  </div>
</section>

<!-- SPECS STRIP -->
<section class="specs-strip">
  <div style="text-align:center;margin-bottom:24px">
    <span class="spec-badge">3.0T V6</span>
  </div>
  <div class="specs-strip-inner">
    <div class="spec-item">
      <div class="spec-value">206 <sub>KW</sub></div>
      <div class="spec-label" data-i18n="model.maxPower">MAX. POWER</div>
    </div>
    <div class="spec-item">
      <div class="spec-value">420 <sub>N·M</sub></div>
      <div class="spec-label" data-i18n="model.maxTorque">MAX. TORQUE</div>
    </div>
    <div class="spec-item">
      <div class="spec-value">3.0 <sub>T</sub></div>
      <div class="spec-label" data-i18n="model.engine">ENGINE</div>
    </div>
    <div class="spec-item">
      <div class="spec-value">8 <sub>AT</sub></div>
      <div class="spec-label" data-i18n="model.transmission">TRANSMISSION</div>
    </div>
    <div class="spec-item">
      <div class="spec-value">2800 <sub>MM</sub></div>
      <div class="spec-label" data-i18n="model.wheelbase">WHEELBASE</div>
    </div>
  </div>
</section>

<!-- FEATURE: EXTERIOR -->
<section class="feature">
  <div class="feature-full" style="min-height:85vh">
    <img src="https://www.baicglobal.com/file/common/image/2023/06/19/pc5_20230619105543A205.jpg" alt="BJ80 Exterior">
    <div class="feature-overlay">
      <h3 data-i18n="bj80.commandingPresence">Commanding Presence</h3>
      <p data-i18n="bj80.commandingPresenceDesc">The BJ80's imposing silhouette combines military-grade toughness with premium luxury, featuring a bold front grille and muscular body lines that command attention on any terrain.</p>
    </div>
  </div>
</section>

<!-- FEATURE: INTERIOR (Side layout) -->
<section class="feature">
  <div class="feature-side">
    <div class="feature-side-img">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/15/pc2_20230615184354A148.jpg" alt="BJ80 Interior">
    </div>
    <div class="feature-side-content">
      <h3 data-i18n="bj80.luxuriousInterior">Luxurious Interior</h3>
      <p data-i18n="bj80.luxuriousInteriorDesc">Nappa leather seats, matte mahogany accents, chamois leather headliner — the BJ80 Mount Everest edition wraps you in premium comfort befitting a flagship. Heated and ventilated front seats with driver memory function ensure every journey begins in perfect comfort.</p>
    </div>
  </div>
</section>

<!-- FEATURE: DASHBOARD -->
<section class="feature">
  <div class="feature-full" style="min-height:80vh">
    <img src="https://www.baicglobal.com/file/common/image/2023/06/15/pc3_20230615184750A167.jpg" alt="BJ80 Dashboard">
    <div class="feature-overlay">
      <h3 data-i18n="bj80.dualDisplay">10.25" LCD Meter + 8" Display</h3>
      <p data-i18n="bj80.dualDisplayDesc">Dual-screen digital cockpit with 10.25 inch LCD instrument cluster and 8 inch central display, providing essential driving information and entertainment in an intuitive layout.</p>
    </div>
  </div>
</section>

<!-- FEATURE: DUO - Seats + Detail -->
<section class="feature">
  <div class="feature-duo">
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/15/pc6_20230615184843A152.jpg" alt="BJ80 Seats">
      <div class="feature-duo-overlay">
        <h4 data-i18n="bj80.premiumSeating">Premium Seating</h4>
        <p data-i18n="bj80.premiumSeatingDesc">Independent rear seats with heating and co-pilot boss key for rear passenger comfort</p>
      </div>
    </div>
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/15/pc9_20230615185058A154.jpg" alt="BJ80 Detail">
      <div class="feature-duo-overlay">
        <h4 data-i18n="bj80.precisionEngineering">Precision Engineering</h4>
        <p data-i18n="bj80.precisionEngineeringDesc">Every detail crafted with military-grade precision and attention to quality</p>
      </div>
    </div>
  </div>
</section>

<!-- FEATURE: OFF-ROAD -->
<section class="feature">
  <div class="feature-full" style="min-height:85vh">
    <img src="https://www.baicglobal.com/file/common/image/2023/06/16/pc9 拷贝_20230616101507A155.jpg" alt="BJ80 Off-road">
    <div class="feature-overlay">
      <h3 data-i18n="bj80.separateFrame">Separate Frame Construction</h3>
      <p data-i18n="bj80.separateFrameDesc">Built on a rugged separate frame with double wishbone torsion bar spring independent front suspension and five connecting rod rear suspension. Part-time 4WD with mechanical rear differential lock conquers the most demanding terrains.</p>
    </div>
  </div>
</section>

<!-- FEATURE: SIDE - Capability -->
<section class="feature">
  <div class="feature-side" style="direction:rtl">
    <div class="feature-side-img" style="direction:ltr">
      <img src="https://www.baicglobal.com/file/common/image/2022/09/14/pc7_20220914150513A007.jpg" alt="BJ80 Capability">
    </div>
    <div class="feature-side-content" style="direction:ltr">
      <h3 data-i18n="bj80.allTerrainMastery">All-Terrain Mastery</h3>
      <p data-i18n="bj80.allTerrainMasteryDesc">39° approach angle, 33° departure angle, and 25° ramp angle. Multiple driving modes including Snowfield, Sport, Comfort, and ECO ensure optimal performance across every environment. The mechanical rear differential lock provides unstoppable traction.</p>
    </div>
  </div>
</section>

<!-- FEATURE: DUO - Detail + Engine -->
<section class="feature">
  <div class="feature-duo">
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2023/06/16/pc4 拷贝_20230616101624A158.jpg" alt="BJ80 Detail">
      <div class="feature-duo-overlay">
        <h4 data-i18n="bj80.flagshipDetails">Flagship Details</h4>
        <p data-i18n="bj80.flagshipDetailsDesc">Chrome accents, power sunroof, and front boneless wiper with rain sensor</p>
      </div>
    </div>
    <div class="feature-duo-item">
      <img src="https://www.baicglobal.com/file/common/image/2024/02/07/pc7_20240207140725A055.jpg" alt="BJ80 Power">
      <div class="feature-duo-overlay">
        <h4 data-i18n="bj80.v6Power">3.0T V6 Power</h4>
        <p data-i18n="bj80.v6PowerDesc">206kW max power and 420N·m torque paired with 8-speed automatic transmission</p>
      </div>
    </div>
  </div>
</section>

<!-- FEATURE: SAFETY -->
<section class="feature">
  <div class="feature-full" style="min-height:75vh">
    <img src="https://www.baicglobal.com/file/common/image/2023/06/13/2222222_20230613110840A125.png" alt="BJ80 Safety">
    <div class="feature-overlay">
      <h3 data-i18n="bj80.militaryGradeSafety">Military-Grade Safety</h3>
      <p data-i18n="bj80.militaryGradeSafetyDesc">Comprehensive safety suite including ABS+EBD, ESP, TCS, HHC, HDC, Roll Movement Intervention, front and rear parking sensors, reversing camera, driving recorder, and 6 airbags for complete occupant protection.</p>
    </div>
  </div>
</section>

