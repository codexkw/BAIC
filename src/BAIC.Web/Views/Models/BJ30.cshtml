    <div class="spec-item">
      <div class="spec-value">305 <span>N·M</span></div>
      <div class="spec-label" data-i18n="model.maxTorque">TORQUE</div>
    </div>
    <div class="spec-item">
      <div class="spec-value">2.0 <span>T</span></div>
      <div class="spec-label" data-i18n="model.engine">ENGINE</div>
    </div>
    <div class="spec-item">
      <div class="spec-value">7 <span>DCT</span></div>
      <div class="spec-label" data-i18n="model.transmission">TRANSMISSION</div>
