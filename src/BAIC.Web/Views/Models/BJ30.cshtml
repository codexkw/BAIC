@{
    ViewData["Title"] = "BJ30";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/bj30.css" asp-append-version="true" />
}

<!-- HERO KV -->
<section class="hero-kv">
  <img src="~/images/baicglobal/file/public/static/bj30/images/pc/kv.jpg" alt="BAIC BJ30">
  <div class="hero-kv-overlay">
    <div class="hero-btns">
      <a asp-controller="Models" asp-action="TestDrive" asp-route-model="BJ30" class="hero-btn" data-i18n="model.testDrive">Test Drive</a>
      <a href="https://www.baicglobal.com/vrbj30/" class="hero-btn vr" target="_blank" rel="noopener" data-i18n="model.viewVR">View VR</a>
    </div>
  </div>
</section>

<!-- VIDEO SECTION -->
<section class="video-section">
  <video src="~/images/baicglobal/file/public/static/bj30/BJ30.mp4"
         poster="~/images/baicglobal/file/public/static/bj30/images/视频.jpg"
         preload="metadata" controls playsinline loop>
  </video>
</section>

<!-- COLOR PICKER -->
<section class="color-section">
  <div class="color-bg">
    <img src="~/images/baicglobal/file/public/static/bj30/images/color-bg.jpg" alt="">
  </div>
  <button class="palette-toggle" id="paletteToggle" aria-label="Toggle color picker" type="button">
    <img src="~/images/baicglobal/nuxt/open.png" alt="">
  </button>
  <div class="color-stage">
    <div class="color-track" id="colorTrack">
      <div class="color-slide active" data-color="绿"><img src="~/images/baicglobal/file/public/static/bj30/images/color/绿.png" alt="BJ30 Green"></div>
      <div class="color-slide" data-color="白"><img src="~/images/baicglobal/file/public/static/bj30/images/color/白.png" alt="BJ30 White"></div>
      <div class="color-slide" data-color="灰"><img src="~/images/baicglobal/file/public/static/bj30/images/color/灰.png" alt="BJ30 Grey"></div>
      <div class="color-slide" data-color="天青蓝"><img src="~/images/baicglobal/file/public/static/bj30/images/color/天青蓝.png" alt="BJ30 Sky Blue"></div>
      <div class="color-slide" data-color="黑"><img src="~/images/baicglobal/file/public/static/bj30/images/color/黑.png" alt="BJ30 Black"></div>
      <div class="color-slide" data-color="泡泡灰"><img src="~/images/baicglobal/file/public/static/bj30/images/color/泡泡灰.png" alt="BJ30 Bubble Grey"></div>
      <div class="color-slide" data-color="铂金灰"><img src="~/images/baicglobal/file/public/static/bj30/images/color/铂金灰.png" alt="BJ30 Platinum Grey"></div>
    </div>
  </div>
  <div class="color-dots" id="colorDots">
    <div class="color-dot active" style="background:#5a7a4a" data-color="绿" title="Green"></div>
    <div class="color-dot" style="background:#e8e6e0" data-color="白" title="White"></div>
    <div class="color-dot" style="background:#7a7a78" data-color="灰" title="Grey"></div>
    <div class="color-dot" style="background:#6b8fa3" data-color="天青蓝" title="Sky Blue"></div>
    <div class="color-dot" style="background:#1a1a1a" data-color="黑" title="Black"></div>
    <div class="color-dot" style="background:#b8b0a8" data-color="泡泡灰" title="Bubble Grey"></div>
    <div class="color-dot" style="background:#8a8580" data-color="铂金灰" title="Platinum Grey"></div>
  </div>
</section>

<!-- EXQUISITE PICTURE CAROUSEL -->
<section class="exquisite-picture">
  <div class="exq-track" id="exqTrack">
    <div class="exq-slide"><img src="~/images/baicglobal/file/common/image/2024/10/29/1_20241029181932A206.jpg" alt="BAIC BJ30"></div>
    <div class="exq-slide"><img src="~/images/baicglobal/file/common/image/2024/10/29/2_20241029181938A207.jpg" alt="BAIC BJ30"></div>
    <div class="exq-slide"><img src="~/images/baicglobal/file/common/image/2024/10/29/3_20241029181944A208.jpg" alt="BAIC BJ30"></div>
    <div class="exq-slide"><img src="~/images/baicglobal/file/common/image/2024/10/29/4_20241029181950A209.jpg" alt="BAIC BJ30"></div>
    <div class="exq-slide"><img src="~/images/baicglobal/file/common/image/2024/10/29/5_20241029181955A210.jpg" alt="BAIC BJ30"></div>
    <div class="exq-slide"><img src="~/images/baicglobal/file/common/image/2024/10/29/6_20241029182001A211.jpg" alt="BAIC BJ30"></div>
  </div>
  <div class="exq-dots" id="exqDots">
    <button class="exq-dot active" data-i="0" aria-label="Slide 1"></button>
    <button class="exq-dot" data-i="1" aria-label="Slide 2"></button>
    <button class="exq-dot" data-i="2" aria-label="Slide 3"></button>
    <button class="exq-dot" data-i="3" aria-label="Slide 4"></button>
    <button class="exq-dot" data-i="4" aria-label="Slide 5"></button>
    <button class="exq-dot" data-i="5" aria-label="Slide 6"></button>
  </div>
</section>

<!-- SPECS STRIP -->
<section class="specs-strip">
