@section Scripts {
<script>
// Color picker — palette toggle reveals the dots; clicking a dot cross-fades the slide
const paletteToggle = document.getElementById('paletteToggle');
const colorSection = document.querySelector('.color-section');
if (paletteToggle && colorSection) {
  paletteToggle.addEventListener('click', () => {
    colorSection.classList.toggle('palette-open');
  });
}
document.querySelectorAll('.color-dot').forEach(dot=>{
  dot.addEventListener('click',()=>{
    const colorName = dot.dataset.color;
    document.querySelectorAll('.color-dot').forEach(d=>d.classList.remove('active'));
    dot.classList.add('active');
    document.querySelectorAll('.color-slide').forEach(s=>{
      s.classList.toggle('active', s.dataset.color === colorName);
    });
  });
});

// Exquisite-picture carousel — translate track by index*(slide+gap), with drag support
(function(){
  const track = document.getElementById('exqTrack');
  if (!track) return;
  const slides = track.querySelectorAll('.exq-slide');
  const dots = document.querySelectorAll('.exq-dot');
  const total = slides.length;
  let idx = 0;
  const setIdx = (i) => {
    idx = (i + total) % total;
    const slide = slides[0];
    const styles = getComputedStyle(slide);
    const gap = parseFloat(getComputedStyle(track).gap || 0);
    const slideW = slide.getBoundingClientRect().width;
    const containerW = track.parentElement.getBoundingClientRect().width;
    // center the active slide
    const offset = (containerW / 2) - (slideW / 2) - idx * (slideW + gap);
    track.style.transform = `translate3d(${offset}px,0,0)`;
    slides.forEach((s, j) => s.classList.toggle('active', j === idx));
    dots.forEach((d, j) => d.classList.toggle('active', j === idx));
  };
  dots.forEach(d => d.addEventListener('click', () => setIdx(parseInt(d.dataset.i, 10))));
  slides.forEach((s, j) => s.addEventListener('click', () => { if (j !== idx) setIdx(j); }));
  // drag / swipe
  let downX = null, downIdx = 0;
  const onDown = (e) => { downX = (e.touches ? e.touches[0].clientX : e.clientX); downIdx = idx; track.style.transition = 'none'; };
  const onMove = (e) => {
    if (downX == null) return;
    const x = (e.touches ? e.touches[0].clientX : e.clientX);
    const dx = x - downX;
    const slideW = slides[0].getBoundingClientRect().width;
    const gap = parseFloat(getComputedStyle(track).gap || 0);
    const containerW = track.parentElement.getBoundingClientRect().width;
    const baseOffset = (containerW / 2) - (slideW / 2) - downIdx * (slideW + gap);
    track.style.transform = `translate3d(${baseOffset + dx}px,0,0)`;
  };
  const onUp = (e) => {
    if (downX == null) return;
    const x = (e.changedTouches ? e.changedTouches[0].clientX : e.clientX);
    const dx = x - downX;
    track.style.transition = '';
    const slideW = slides[0].getBoundingClientRect().width;
    const threshold = slideW / 4;
    let next = downIdx;
    if (dx > threshold) next = downIdx - 1;
    else if (dx < -threshold) next = downIdx + 1;
    setIdx(Math.max(0, Math.min(total - 1, next)));
    downX = null;
  };
  track.addEventListener('mousedown', onDown);
  window.addEventListener('mousemove', onMove);
  window.addEventListener('mouseup', onUp);
  track.addEventListener('touchstart', onDown, { passive: true });
  track.addEventListener('touchmove', onMove, { passive: true });
  track.addEventListener('touchend', onUp);
  window.addEventListener('resize', () => setIdx(idx));
  // initial layout once images report size
  if (document.readyState === 'complete') setIdx(0);
  else window.addEventListener('load', () => setIdx(0));
})();

// Split feature tabs
document.querySelectorAll('.feature-split-tabs').forEach(tabGroup => {
  const parent = tabGroup.closest('.feature-split');
  const imgEl = parent.querySelector('img');
  const titleEl = parent.nextElementSibling?.querySelector('h3') || parent.parentElement.querySelector('[id^=splitTitle]');
  const descEl = parent.nextElementSibling?.querySelector('p') || parent.parentElement.querySelector('[id^=splitDesc]');

  tabGroup.querySelectorAll('.feature-split-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      tabGroup.querySelectorAll('.feature-split-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      if (imgEl) {
        imgEl.style.opacity = '0';
        setTimeout(() => {
          imgEl.src = tab.dataset.img;
          imgEl.style.opacity = '1';
        }, 200);
      }
      // Update text from sibling content panel
      const splitParent = tabGroup.closest('.feature-split');
      const contentPanel = splitParent.querySelector('div[style*="flex-direction"]');
      if (contentPanel) {
        const h3 = contentPanel.querySelector('h3');
        const p = contentPanel.querySelector('p');
        if (h3) h3.textContent = tab.dataset.title;
        if (p) p.textContent = tab.dataset.desc;
      }
    });
  });
});
</script>
}
