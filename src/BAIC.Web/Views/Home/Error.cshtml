@{
    ViewData["Title"] = "Error";
}

<section style="min-height:80vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:40px;margin-top:64px">
    <h1 style="font-size:72px;font-weight:200;letter-spacing:4px;margin-bottom:16px">Oops</h1>
    <p style="font-size:16px;color:#929292;margin-bottom:32px">Something went wrong. Please try again later.</p>
    <a asp-controller="Home" asp-action="Index" style="padding:12px 36px;font-size:13px;letter-spacing:1px;border:1px solid #000;color:#000;transition:all .3s;text-decoration:none">BACK TO HOME</a>
</section>
