@section Scripts {
<script>
// Hero carousel
let cur=0;const slides=document.querySelectorAll('.hero-slide'),dots=document.querySelectorAll('.hero-dot');
function goHero(i){slides[cur].classList.remove('active');dots[cur].classList.remove('active');cur=((i%slides.length)+slides.length)%slides.length;slides[cur].classList.add('active');dots[cur].classList.add('active')}
function heroNav(d){goHero(cur+d)}
dots.forEach(d=>d.addEventListener('click',()=>goHero(+d.dataset.i)));
setInterval(()=>heroNav(1),5000);

// ========== EXPLORE YOUR BAIC - Interactive 360 Model Loader ==========
const car360Img = document.getElementById('car360Img');
const car360Loader = document.getElementById('car360Loader');
const car360Name = document.getElementById('car360Name');
const btnViewVR = document.getElementById('btnViewVR');
const car360Stage = document.getElementById('car360Stage');

// Map model names to their 360 image base paths
const modelPaths = {
  'BJ30':          'https://www.baicglobal.com/file/home360/BJ30/color0/',
  'BJ80':          'https://www.baicglobal.com/file/home360/BJ80/color0/',
  'BJ60':          'https://www.baicglobal.com/file/home360/BJ60/color0/',
  'BJ40 PLUS':     'https://www.baicglobal.com/file/home360/BJ40PLUS/color0/',
  'BJ40 PLUS RHD': 'https://www.baicglobal.com/file/home360/BJ40PLUS/color0/',
  'BJ40 PRO':      'https://www.baicglobal.com/file/home360/BJ40PRO/color0/',
  'BJ40 SE':       'https://www.baicglobal.com/file/home360/BJ40SE/color0/',
  'F40':           'https://www.baicglobal.com/file/home360/F40/color0/',
  'EU5':           'https://www.baicglobal.com/file/home360/EU5/color0/',
  'X35':           'https://www.baicglobal.com/file/home360/X35/color0/',
};

let currentModel = 'BJ30';
let currentFrame = 0;
const totalFrames = 36; // 360 images have 36 frames (10° each)
let frameImages = {}; // cache per model
let isDragging = false;
let dragStartX = 0;

// Preload a few frames for current model
function preloadFrames(model, count) {
  if (!frameImages[model]) frameImages[model] = {};
  const base = modelPaths[model] || modelPaths['BJ30'];
  for (let i = 0; i < count; i++) {
    if (!frameImages[model][i]) {
      const img = new Image();
      img.src = base + i + '.avif';
      frameImages[model][i] = img;
    }
  }
}

// Switch model with loading animation
function switchModel(modelName, vrUrl) {
  if (modelName === currentModel) return;

  currentModel = modelName;
  currentFrame = 0;

  // Show loader, fade out current image
  car360Loader.classList.add('visible');
  car360Img.classList.remove('loaded');
  car360Img.classList.add('loading');
  car360Name.style.opacity = '0.3';

  // Build the image URL
  const base = modelPaths[modelName] || modelPaths['BJ30'];
  const newSrc = base + '0.avif';

  // Load new image
  const testImg = new Image();
  testImg.onload = function() {
    car360Img.src = newSrc;
    // Small delay for smooth transition
    setTimeout(() => {
      car360Img.classList.remove('loading');
      car360Img.classList.add('loaded');
      car360Loader.classList.remove('visible');
      car360Name.textContent = modelName;
      car360Name.style.opacity = '1';
    }, 300);
    // Preload rest of frames in background
    preloadFrames(modelName, Math.min(totalFrames, 12));
  };
  testImg.onerror = function() {
    // If 360 images aren't available, just show model name
    car360Img.classList.remove('loading');
    car360Img.classList.add('loaded');
    car360Loader.classList.remove('visible');
    car360Name.textContent = modelName;
    car360Name.style.opacity = '1';
  };
  testImg.src = newSrc;

  // Update VR link
  if (btnViewVR) btnViewVR.href = vrUrl || '#';
}

// Car thumbnail click handlers
document.querySelectorAll('.car-thumb').forEach(thumb => {
  thumb.addEventListener('click', () => {
    // Update active state
    document.querySelectorAll('.car-thumb').forEach(x => x.classList.remove('active'));
    thumb.classList.add('active');

    // Switch model
    const model = thumb.dataset.model;
    const vr = thumb.dataset.vr;
    switchModel(model, vr);
  });
});

// 360 Drag Rotation
car360Stage.addEventListener('mousedown', (e) => {
  isDragging = true;
  dragStartX = e.clientX;
  e.preventDefault();
});

car360Stage.addEventListener('touchstart', (e) => {
  isDragging = true;
  dragStartX = e.touches[0].clientX;
}, { passive: true });

function handleDragMove(clientX) {
  if (!isDragging) return;
  const diff = clientX - dragStartX;
  const threshold = 30; // pixels per frame

  if (Math.abs(diff) > threshold) {
    const direction = diff > 0 ? 1 : -1;
    currentFrame = ((currentFrame + direction) % totalFrames + totalFrames) % totalFrames;

    const base = modelPaths[currentModel] || modelPaths['BJ30'];
    const frameSrc = base + currentFrame + '.avif';

    // Check if cached
    if (frameImages[currentModel] && frameImages[currentModel][currentFrame]) {
      car360Img.src = frameSrc;
    } else {
      car360Img.src = frameSrc;
      // Cache it
      if (!frameImages[currentModel]) frameImages[currentModel] = {};
      const img = new Image();
      img.src = frameSrc;
      frameImages[currentModel][currentFrame] = img;
    }

    dragStartX = clientX;
  }
}

document.addEventListener('mousemove', (e) => handleDragMove(e.clientX));
document.addEventListener('touchmove', (e) => handleDragMove(e.touches[0].clientX), { passive: true });
document.addEventListener('mouseup', () => { isDragging = false; });
document.addEventListener('touchend', () => { isDragging = false; });

// Category tabs - filter thumbnails
document.querySelectorAll('.cat-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.cat-tab').forEach(x => x.classList.remove('active'));
    tab.classList.add('active');

    const cat = tab.dataset.cat;
    const thumbs = document.querySelectorAll('.car-thumb');

    thumbs.forEach(t => {
      if (cat === 'all' || t.dataset.cat === cat) {
        t.style.display = '';
      } else {
        t.style.display = 'none';
      }
    });

    // Select the first visible thumb
    const firstVisible = document.querySelector('.car-thumb:not([style*="display: none"])');
    if (firstVisible) {
      document.querySelectorAll('.car-thumb').forEach(x => x.classList.remove('active'));
      firstVisible.classList.add('active');
      const model = firstVisible.dataset.model;
      const vr = firstVisible.dataset.vr || '#';
      switchModel(model, vr);
    }
  });
});

// Initial preload
preloadFrames('BJ30', 6);
car360Img.classList.add('loaded');

// ========== WORLD MAP - Dot Matrix Canvas ==========
(function(){
const canvas = document.getElementById('mapCanvas');
const ctx = canvas.getContext('2d');
const dpr = window.devicePixelRatio || 1;
const containerW = canvas.parentElement.offsetWidth;
const W = Math.min(1200, containerW);
const H = Math.round(W * 620 / 1200);
canvas.width = W * dpr; canvas.height = H * dpr;
canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
ctx.scale(dpr, dpr);

// Simplified world continent coordinate data as polygon outlines
// Each continent is an array of [x%, y%] points scaled to canvas
const continents = {
  northAmerica: [
    // Main body
    [[12,12],[15,10],[18,9],[21,10],[24,11],[26,13],[25,16],[23,18],[22,21],[24,22],[26,23],[25,26],[23,28],[21,30],[19,32],[18,34],[16,34],[15,32],[14,30],[12,28],[10,25],[9,22],[10,18],[11,15]],
    // Greenland
    [[28,6],[30,5],[33,6],[34,8],[33,10],[31,11],[29,10],[28,8]],
  ],
  southAmerica: [
    [[22,38],[24,36],[26,37],[28,38],[29,41],[30,44],[30,48],[29,52],[28,56],[27,60],[26,64],[25,68],[24,72],[22,74],[21,72],[20,68],[19,64],[19,60],[19,56],[20,50],[20,46],[21,42]],
  ],
  europe: [
    [[42,10],[44,8],[46,8],[48,9],[50,10],[51,12],[50,14],[49,16],[47,18],[45,18],[44,17],[43,15],[42,13]],
    // Scandinavia
    [[44,5],[46,4],[48,5],[47,8],[45,8],[44,7]],
    // UK
    [[40,10],[41,9],[42,10],[41,12],[40,11]],
  ],
  africa: [
    [[42,22],[44,20],[47,20],[50,21],[52,23],[53,26],[54,30],[54,34],[53,38],[52,42],[50,46],[48,48],[46,50],[44,48],[42,46],[40,42],[39,38],[38,34],[38,30],[39,26],[40,23]],
  ],
  asia: [
    // Main body
    [[52,8],[55,6],[58,5],[62,5],[66,6],[70,7],[74,8],[78,10],[80,12],[82,14],[84,16],[85,18],[84,20],[82,22],[80,23],[78,24],[76,26],[73,27],[70,28],[68,28],[66,27],[64,26],[62,24],[60,22],[58,20],[56,18],[54,16],[52,14],[51,12],[52,10]],
    // India
    [[62,24],[64,26],[66,28],[67,32],[66,36],[64,38],[62,36],[60,34],[60,30],[61,26]],
    // SE Asia
    [[72,28],[74,30],[76,32],[78,34],[76,36],[74,34],[72,32],[71,30]],
  ],
  middleEast: [
    [[50,20],[52,18],[55,18],[57,20],[56,24],[54,26],[52,25],[50,23]],
  ],
  australia: [
    [[78,42],[80,40],[83,40],[86,41],[88,43],[88,46],[87,49],[85,50],[82,50],[80,49],[78,47],[77,44]],
    // NZ
    [[90,50],[91,48],[92,50],[91,52],[90,51]],
  ],
  japan: [
    [[82,12],[83,14],[84,16],[83,18],[82,16],[81,14]],
  ],
  indonesia: [
    [[74,36],[76,35],[78,36],[80,37],[82,38],[80,39],[78,38],[76,37]],
  ],
};

// Convert percentage coords to canvas pixels
function toCanvas(points) {
  return points.map(p => [p[0] * W / 100, p[1] * H / 100]);
}

// Check if point is inside polygon (ray casting)
function pointInPoly(x, y, poly) {
  let inside = false;
  for (let i = 0, j = poly.length - 1; i < poly.length; j = i++) {
    const xi = poly[i][0], yi = poly[i][1];
    const xj = poly[j][0], yj = poly[j][1];
    if ((yi > y) !== (yj > y) && x < (xj - xi) * (y - yi) / (yj - yi) + xi) {
      inside = !inside;
    }
  }
  return inside;
}

// Draw dots
const dotSize = 2.2;
const spacing = 8;

// Collect all polygon arrays
const allPolys = [];
Object.values(continents).forEach(polyGroup => {
  polyGroup.forEach(poly => allPolys.push(toCanvas(poly)));
});

// Draw background dots grid (very faint)
ctx.fillStyle = 'rgba(255,255,255,0.03)';
for (let x = 0; x < W; x += spacing) {
  for (let y = 0; y < H; y += spacing) {
    ctx.beginPath();
    ctx.arc(x, y, 1, 0, Math.PI * 2);
    ctx.fill();
  }
}

// Draw continent dots
for (let x = 0; x < W; x += spacing) {
  for (let y = 0; y < H; y += spacing) {
    let inContinent = false;
    for (const poly of allPolys) {
      if (pointInPoly(x, y, poly)) {
        inContinent = true;
        break;
      }
    }
    if (inContinent) {
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.beginPath();
      ctx.arc(x, y, dotSize, 0, Math.PI * 2);
      ctx.fill();
    }
  }
}

// BAIC presence locations [x%, y%, label, isMain]
const locations = [
  // Middle East (main market)
  [54, 23, 'Saudi Arabia', true],
  [56, 22, 'UAE', true],
  [52, 21, 'Iraq', false],
  [50, 22, 'Egypt', false],
  // Africa
  [44, 30, 'Nigeria', false],
  [48, 34, 'Kenya', false],
  [44, 44, 'South Africa', false],
  [42, 26, 'Morocco', false],
  // Asia
  [76, 12, 'China', true],
  [68, 20, 'Pakistan', false],
  [72, 30, 'Thailand', false],
  [76, 34, 'Malaysia', false],
  [80, 36, 'Indonesia', false],
  [74, 18, 'Kazakhstan', false],
  // South America
  [24, 48, 'Brazil', false],
  [22, 56, 'Chile', false],
  [26, 44, 'Colombia', false],
  [20, 42, 'Ecuador', false],
  // Central America / Caribbean
  [18, 32, 'Mexico', false],
  [22, 34, 'Dominican Rep.', false],
  // Europe
  [46, 12, 'Russia', false],
  // Australia
  [84, 46, 'Australia', false],
];

locations.forEach(loc => {
  const cx = loc[0] * W / 100;
  const cy = loc[1] * H / 100;
  const isMain = loc[3];

  // Glow
  if (isMain) {
    const grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, 18);
    grd.addColorStop(0, 'rgba(59,130,246,0.25)');
    grd.addColorStop(1, 'rgba(59,130,246,0)');
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.arc(cx, cy, 18, 0, Math.PI * 2);
    ctx.fill();
  }

  // Outer ring
  ctx.strokeStyle = isMain ? 'rgba(59,130,246,0.5)' : 'rgba(59,130,246,0.3)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.arc(cx, cy, isMain ? 8 : 6, 0, Math.PI * 2);
  ctx.stroke();

  // Inner dot
  ctx.fillStyle = isMain ? 'rgba(59,130,246,0.9)' : 'rgba(59,130,246,0.7)';
  ctx.beginPath();
  ctx.arc(cx, cy, isMain ? 3.5 : 2.5, 0, Math.PI * 2);
  ctx.fill();
});

})();
</script>
}
