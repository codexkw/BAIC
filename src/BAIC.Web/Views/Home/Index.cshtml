<!-- NEWS FEEDS -->
<section class="news">
  <h4 class="section-title" data-i18n="home.newsFeeds">NEWS FEEDS</h4>
  <div class="news-scroll-wrap">
    <div class="news-arrow left" onclick="document.getElementById('newsScroll').scrollBy({left:-300,behavior:'smooth'})">&#10094;</div>
    <div class="news-arrow right" onclick="document.getElementById('newsScroll').scrollBy({left:300,behavior:'smooth'})">&#10095;</div>
    <div class="news-scroll" id="newsScroll">
    <a href="#" class="news-card"><div class="news-card-img"><img src="~/images/baicglobal/file/common/image/2026/02/10/m_20260210102346A088.avif" alt=""></div><div class="news-card-body"><h4>BAIC ARCFOX 77° Concept Car Wins 2025 Red Dot Design Award</h4></div></a>
    <a href="#" class="news-card"><div class="news-card-img"><img src="~/images/baicglobal/file/common/image/2025/12/19/微信图片_20251219100817_4813_28_20251219101602A111.jpg" alt=""></div><div class="news-card-body"><h4>SAFETY AS FOUNDATION, INNOVATION AS DIRECTION: BAIC'S JOURNEY IN BUILDING A COMPREHENSIVE SAFETY ASSURANCE SYSTEM FOR INTELLIGENT CONNECTED VEHICLES</h4></div></a>
    <a href="#" class="news-card"><div class="news-card-img"><img src="~/images/baicglobal/file/common/image/2025/11/29/画板 2_20251129205842A082.png" alt=""></div><div class="news-card-body"><h4>BAIC GLOBAL DISTRIBUTORS BUSINESS CONFERENCE OPENS, THREE MAJOR BRANDS JOINTLY EMBARK ON A NEW STAGE OF GLOBAL DEVELOPMENT</h4></div></a>
