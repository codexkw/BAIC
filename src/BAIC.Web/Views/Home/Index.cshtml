@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/homepage.css" asp-append-version="true" />
}

<!-- HERO -->
<section class="hero">
  <div class="hero-slide active" data-i="0">
    <img class="hero-slide-img" src="~/images/baicglobal/file/common/image/2025/07/09/20250609124156A121_20250709165951A004.avif" alt="BJ40 PRO">
    <div class="hero-slide-content">
      <div class="hero-model-text">BJ40 PRO</div>
      <div class="hero-btns"><a asp-controller="Models" asp-action="TestDrive" asp-route-model="BJ40 PRO" class="hero-btn" data-i18n="home.testDrive">Test Drive</a></div>
    </div>
  </div>
  <div class="hero-slide" data-i="1">
    <img class="hero-slide-img" src="~/images/baicglobal/file/common/image/2025/07/18/111 (1)_20250718095304A139.webp" alt="X55 II">
    <div class="hero-slide-content">
      <div class="hero-model-text">X55 II</div>
      <div class="hero-btns"><a asp-controller="Models" asp-action="TestDrive" asp-route-model="X55 II" class="hero-btn" data-i18n="home.testDrive">Test Drive</a></div>
    </div>
  </div>
  <div class="hero-slide" data-i="2">
    <img class="hero-slide-img" src="~/images/baicglobal/file/common/image/2025/07/09/20250603112844A054_20250709170031A007.avif" alt="BJ30">
    <div class="hero-slide-content">
      <div class="hero-model-text">BJ30</div>
      <div class="hero-btns"><a asp-controller="Models" asp-action="TestDrive" asp-route-model="BJ30" class="hero-btn" data-i18n="home.testDrive">Test Drive</a></div>
    </div>
  </div>
  <div class="hero-slide" data-i="3">
    <img class="hero-slide-img" src="~/images/baicglobal/file/common/image/2025/07/18/222_20250718094809A133.webp" alt="BJ60">
    <div class="hero-slide-content">
      <div class="hero-model-text">BJ60</div>
      <div class="hero-btns"><a asp-controller="Models" asp-action="TestDrive" asp-route-model="BJ60" class="hero-btn" data-i18n="home.testDrive">Test Drive</a></div>
    </div>
  </div>
  <div class="hero-slide" data-i="4">
    <img class="hero-slide-img" src="~/images/baicglobal/file/common/image/2025/07/09/x7_20250218154801A963_20250709170103A010.avif" alt="X7">
    <div class="hero-slide-content">
      <div class="hero-model-text">X7</div>
      <div class="hero-btns"><a asp-controller="Models" asp-action="TestDrive" asp-route-model="ALL NEW X7" class="hero-btn" data-i18n="home.testDrive">Test Drive</a></div>
    </div>
  </div>
  <button class="hero-arrow left" onclick="heroNav(-1)">&#10094;</button>
  <button class="hero-arrow right" onclick="heroNav(1)">&#10095;</button>
  <div class="hero-dots" id="heroDots">
    <div class="hero-dot active" data-i="0"></div>
    <div class="hero-dot" data-i="1"></div>
    <div class="hero-dot" data-i="2"></div>
    <div class="hero-dot" data-i="3"></div>
    <div class="hero-dot" data-i="4"></div>
  </div>
</section>

<!-- EXPLORE YOUR BAIC -->
