  <!-- 360 Car View Area -->
  <div class="car-360-wrapper" id="car360Wrapper">
    <!-- Loading spinner overlay -->
    <div class="car-360-loader" id="car360Loader">
      <div class="loader-spinner"></div>
    </div>
    <!-- 360 image container -->
    <div class="car-360-stage" id="car360Stage">
      <img src="~/images/baicglobal/file/home360/BJ30/color0/0.avif" alt="360 View" id="car360Img" draggable="false">
      <!-- 360° rotate icon (follows cursor over the stage) -->
      <div class="car-360-icon" id="icon360" aria-hidden="true">
        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="23" fill="rgba(20,20,20,.85)" stroke="rgba(255,255,255,.25)" stroke-width="1"/>
          <text x="24" y="28" text-anchor="middle" fill="#fff" font-size="11" font-weight="600" font-family="Arial,sans-serif">360&#176;</text>
        </svg>
      </div>
    </div>
    <!-- Color swatches -->
    <div class="car-360-colors" id="car360Colors"></div>
    <!-- Model name display -->
    <div class="car-360-model-name" id="car360Name">BJ30</div>
    <!-- Buttons -->
    <div class="car-360-btns">
      <a asp-controller="Models" asp-action="TestDrive" asp-route-model="BJ30" class="car-360-btn" id="btnTestDrive" data-i18n="home.testDriveBtn">TEST DRIVE</a>
      <a href="https://www.baicglobal.com/vrbj30/" class="car-360-btn" id="btnViewVR" target="_blank" data-i18n="home.viewVRBtn">VIEW VR</a>
    </div>
  </div>
</section>

<!-- INDEX CAPITAL (BAIC About teaser) -->
<section class="index-capital-section">
  <a asp-controller="About" asp-action="Index" class="capital-link">
    <img class="capital-img" src="~/images/baicglobal/file/public/static/aboutUs/bg.webp" alt="BAIC" loading="lazy" />
    <div class="capital-text">
      <img class="capital-logo" src="~/images/baicglobal/file/public/static/aboutUs/logo.webp" alt="BAIC" />
      <span class="capital-tagline" data-i18n="home.capitalTagline">YOUR WISH · OUR WAYS</span>
    </div>
  </a>
</section>

<!-- CONTENT GRID — main 2-column section (baicglobal.com layout) -->
<section class="content-grid">
  <div class="cgrid-main">
    <!-- LEFT column: BAIC IN X + R&D + Learn (CTA) -->
    <div class="cgrid-col cgrid-col-left">
      <a asp-controller="News" asp-action="BaicInX" class="cg-item">
        <img class="cg-bg" src="~/images/baicglobal/file/common/image/2025/07/10/baic914-915_20240506135116A153_20250710175618A105.avif" alt="BAIC IN X" loading="lazy">
        <h3 class="cg-title" data-i18n="home.baicInX">BAIC IN X</h3>
      </a>
      <a asp-controller="About" asp-action="ResearchDevelopment" class="cg-item">
        <img class="cg-bg" src="~/images/baicglobal/file/common/image/2025/07/10/wx_20240422193726_20240422193849A069_20250710175644A106.avif" alt="R&D" loading="lazy">
        <h3 class="cg-title" data-i18n="home.researchDev">RESEARCH & DEVELOPMENT</h3>
      </a>
      <a asp-controller="Innovation" asp-action="ConceptCar2026" class="cg-item cg-item-cta">
        <img class="cg-bg" src="~/images/baicglobal/file/common/image/2025/07/10/more_20240411162958A010_20241202134101A479_20250710175653A107.avif" alt="Learn" loading="lazy">
        <div class="cg-cta">
          <h3 data-i18n="home.learnAboutBaic">LEARN EVERYTHING<br>ABOUT<br>BAIC HERE</h3>
          <span class="cg-view-more" data-i18n="home.viewMore">VIEW MORE</span>
        </div>
      </a>
    </div>
    <!-- RIGHT column: Off-Road + History -->
    <div class="cgrid-col cgrid-col-right">
      <a asp-controller="Innovation" asp-action="OffRoad" class="cg-item">
        <img class="cg-bg" src="~/images/baicglobal/file/common/image/2025/07/10/wx_20240614165242_20240614170812A026_20250710175551A104.avif" alt="Off-Road" loading="lazy">
        <h3 class="cg-title" data-i18n="home.offRoadVehicle">OFF-ROAD VEHICLE</h3>
      </a>
      <a asp-controller="About" asp-action="History" class="cg-item">
        <img class="cg-bg" src="~/images/baicglobal/file/common/image/2025/07/10/1-1_20240527175812A001_20250710175702A108.avif" alt="History" loading="lazy">
        <h3 class="cg-title" data-i18n="home.baicHistory">BAIC HISTORY</h3>
      </a>
    </div>
  </div>
</section>

