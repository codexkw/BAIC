// Static fallback images for models without 360 support
const modelStaticImages = {};
document.querySelectorAll('.car-thumb').forEach(t => {
  const img = t.querySelector('img');
  if (img) modelStaticImages[t.dataset.model] = img.src;
});

let currentModel = 'BJ30';
let currentFrame = 0;
let currentColorIndex = 0;
const totalFrames = 36;
let frameImages = {};
let isDragging = false;
let dragStartX = 0;
let currentModelHas360 = true;

// Get current color object for a model
function getColorObj(modelName, colorIdx) {
  const data = modelData[modelName];
  if (!data || !data.colors[colorIdx]) return null;
  return data.colors[colorIdx];
}

// Get 360 base path for a color that has a CDN path
function get360Base(modelName, colorObj) {
  const data = modelData[modelName];
  if (!data || !data.folder || !colorObj || !colorObj.path) return null;
  return cdn360 + encodeURIComponent(data.folder) + '/' + colorObj.path + '/';
}

// Preload a few frames for current model + color
function preloadFrames(model, colorIdx, count) {
  const colorObj = getColorObj(model, colorIdx);
  const base = get360Base(model, colorObj);
  if (!base) return;
  const key = model + '_' + colorObj.path;
  if (!frameImages[key]) frameImages[key] = {};
  for (let i = 0; i < count; i++) {
    if (!frameImages[key][i]) {
      const img = new Image();
      img.src = base + i + '.avif';
      frameImages[key][i] = img;
    }
  }
}

// Check if a hex is light/white
function isLightColor(hex) {
  return ['#f5f5f5','#f5f5dc','#e8e4d9','#fff','#ffffff','#f8f8f8','#fbfafa',
          '#f6f3f3','#fef9f9','#f9f5f5','#f2f5f7','#f0f2f5','#cbcbcb','#d0d6dd',
          '#b1b3b4','#9aa2a8','#bacbe2','#b9c9e2'].includes(hex.toLowerCase());
}

// Render color swatches for a model
function renderColorSwatches(modelName) {
  car360Colors.innerHTML = '';
  const data = modelData[modelName];
  if (!data || data.colors.length <= 1) {
    car360Colors.style.display = 'none';
    return;
  }
  car360Colors.style.display = 'flex';
  data.colors.forEach((c, i) => {
    const swatch = document.createElement('button');
    swatch.className = 'color-swatch' + (i === currentColorIndex ? ' active' : '');
    // Handle two-tone colors (e.g. "#070707/#FFFFFF")
    const parts = c.rgb.split('/');
    if (parts.length === 2) {
      swatch.style.background = 'linear-gradient(135deg, ' + parts[0] + ' 50%, ' + parts[1] + ' 50%)';
      swatch.classList.add('two-tone');
    } else {
      swatch.style.background = c.rgb;
    }
    if (isLightColor(parts[0]) || (parts[1] && isLightColor(parts[1]))) {
      swatch.classList.add('light');
    }
    swatch.addEventListener('click', () => switchColor(i));
    car360Colors.appendChild(swatch);
  });
}

// Switch color for current model
function switchColor(colorIdx) {
  if (colorIdx === currentColorIndex) return;
  currentColorIndex = colorIdx;
  currentFrame = 0;

  // Update swatch active state
  car360Colors.querySelectorAll('.color-swatch').forEach((s, i) => {
    s.classList.toggle('active', i === colorIdx);
  });

  const colorObj = getColorObj(currentModel, colorIdx);
  if (!colorObj) return;

  // Show loader
  car360Loader.classList.add('visible');
  car360Img.classList.remove('loaded');
  car360Img.classList.add('loading');

  const icon360 = document.getElementById('icon360');

  if (colorObj.path) {
    // 360 color - load from CDN
    currentModelHas360 = true;
    if (icon360) icon360.style.display = '';
    const base = get360Base(currentModel, colorObj);
    const newSrc = base + '0.avif';
    const testImg = new Image();
    testImg.onload = function() {
      car360Img.src = newSrc;
      setTimeout(() => {
        car360Img.classList.remove('loading');
        car360Img.classList.add('loaded');
        car360Loader.classList.remove('visible');
      }, 300);
      preloadFrames(currentModel, colorIdx, Math.min(totalFrames, 12));
    };
    testImg.onerror = function() {
      car360Img.classList.remove('loading');
      car360Img.classList.add('loaded');
      car360Loader.classList.remove('visible');
    };
    testImg.src = newSrc;
  } else if (colorObj.imgUrl) {
    // Static color image
    currentModelHas360 = false;
    if (icon360) icon360.style.display = 'none';
    const imgSrc = cdnStatic + colorObj.imgUrl;
    const testImg = new Image();
    testImg.onload = function() {
      car360Img.src = imgSrc;
      setTimeout(() => {
        car360Img.classList.remove('loading');
        car360Img.classList.add('loaded');
        car360Loader.classList.remove('visible');
      }, 300);
    };
    testImg.onerror = function() {
      car360Img.classList.remove('loading');
      car360Img.classList.add('loaded');
      car360Loader.classList.remove('visible');
    };
    testImg.src = imgSrc;
  }
}

// Switch model with loading animation
function switchModel(modelName, vrUrl) {
  if (modelName === currentModel) return;

  currentModel = modelName;
  currentFrame = 0;
  currentColorIndex = 0;

  const data = modelData[modelName];
  const firstColor = data ? data.colors[0] : null;
  const has360 = !!(firstColor && firstColor.path && data.folder);
  currentModelHas360 = has360;

  // Show/hide 360 icon based on support
  const icon360 = document.getElementById('icon360');
  if (icon360) icon360.style.display = has360 ? '' : 'none';

  // Render color swatches
  renderColorSwatches(modelName);

  // Show loader, fade out current image
  car360Loader.classList.add('visible');
  car360Img.classList.remove('loaded');
  car360Img.classList.add('loading');
  car360Name.style.opacity = '0.3';

  if (has360) {
    const base = get360Base(modelName, firstColor);
    const newSrc = base + '0.avif';

    const testImg = new Image();
    testImg.onload = function() {
      car360Img.src = newSrc;
      setTimeout(() => {
        car360Img.classList.remove('loading');
        car360Img.classList.add('loaded');
        car360Loader.classList.remove('visible');
        car360Name.textContent = modelName;
        car360Name.style.opacity = '1';
      }, 300);
      preloadFrames(modelName, 0, Math.min(totalFrames, 12));
    };
    testImg.onerror = function() {
      showStaticImage(modelName);
    };
    testImg.src = newSrc;
  } else if (firstColor && firstColor.imgUrl) {
    // Static color image model
    const imgSrc = cdnStatic + firstColor.imgUrl;
    const testImg = new Image();
    testImg.onload = function() {
      car360Img.src = imgSrc;
      setTimeout(() => {
        car360Img.classList.remove('loading');
        car360Img.classList.add('loaded');
        car360Loader.classList.remove('visible');
        car360Name.textContent = modelName;
        car360Name.style.opacity = '1';
      }, 300);
    };
    testImg.onerror = function() {
      showStaticImage(modelName);
    };
    testImg.src = imgSrc;
  } else {
    showStaticImage(modelName);
  }

  // Update VR link
  if (btnViewVR) btnViewVR.href = vrUrl || '#';
  // Update Test Drive link with current model
  if (btnTestDrive) btnTestDrive.href = '/Models/TestDrive?model=' + encodeURIComponent(modelName);
}

function showStaticImage(modelName) {
  currentModelHas360 = false;
  const staticSrc = modelStaticImages[modelName];
  if (staticSrc) {
    car360Img.src = staticSrc;
  }
  setTimeout(() => {
    car360Img.classList.remove('loading');
    car360Img.classList.add('loaded');
    car360Loader.classList.remove('visible');
    car360Name.textContent = modelName;
    car360Name.style.opacity = '1';
  }, 300);
  const icon360 = document.getElementById('icon360');
  if (icon360) icon360.style.display = 'none';
  // Hide color swatches for static models
  car360Colors.style.display = 'none';
}

// Car thumbnail click handlers
document.querySelectorAll('.car-thumb').forEach(thumb => {
  thumb.addEventListener('click', () => {
    document.querySelectorAll('.car-thumb').forEach(x => x.classList.remove('active'));
    thumb.classList.add('active');
    const model = thumb.dataset.model;
    const vr = thumb.dataset.vr;
    switchModel(model, vr);
  });
});

// 360 icon follows mouse cursor over the stage
const icon360Mouse = document.getElementById('icon360');
car360Stage.addEventListener('mousemove', (e) => {
  if (!icon360Mouse || !currentModelHas360) return;
  const rect = car360Stage.getBoundingClientRect();
  icon360Mouse.style.left = (e.clientX - rect.left) + 'px';
  icon360Mouse.style.top = (e.clientY - rect.top) + 'px';
  icon360Mouse.style.opacity = '1';
});
car360Stage.addEventListener('mouseleave', () => {
  if (icon360Mouse) icon360Mouse.style.opacity = '0';
});

// 360 Drag Rotation
car360Stage.addEventListener('mousedown', (e) => {
  isDragging = true;
  dragStartX = e.clientX;
  e.preventDefault();
});

car360Stage.addEventListener('touchstart', (e) => {
  isDragging = true;
  dragStartX = e.touches[0].clientX;
}, { passive: true });

function handleDragMove(clientX) {
  if (!isDragging || !currentModelHas360) return;
  const diff = clientX - dragStartX;
  const threshold = 30;

  if (Math.abs(diff) > threshold) {
    const direction = diff > 0 ? 1 : -1;
    currentFrame = ((currentFrame + direction) % totalFrames + totalFrames) % totalFrames;

    const colorObj = getColorObj(currentModel, currentColorIndex);
    const base = get360Base(currentModel, colorObj);
    if (!base) return;
    const frameSrc = base + currentFrame + '.avif';

    car360Img.src = frameSrc;
    const key = currentModel + '_' + colorObj.path;
    if (!frameImages[key]) frameImages[key] = {};
    if (!frameImages[key][currentFrame]) {
      const img = new Image();
      img.src = frameSrc;
      frameImages[key][currentFrame] = img;
    }

    dragStartX = clientX;
  }
}

document.addEventListener('mousemove', (e) => handleDragMove(e.clientX));
document.addEventListener('touchmove', (e) => handleDragMove(e.touches[0].clientX), { passive: true });
document.addEventListener('mouseup', () => { isDragging = false; });
document.addEventListener('touchend', () => { isDragging = false; });

// Category tabs - filter thumbnails
function applyCategoryFilter(cat) {
  document.querySelectorAll('.car-thumb').forEach(t => {
    t.style.display = (t.dataset.cat === cat) ? '' : 'none';
  });
}

document.querySelectorAll('.cat-tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.cat-tab').forEach(x => x.classList.remove('active'));
    tab.classList.add('active');

    const cat = tab.dataset.cat;
    applyCategoryFilter(cat);

    // Select the first visible thumb
    const firstVisible = document.querySelector('.car-thumb:not([style*="display: none"])');
    if (firstVisible) {
      document.querySelectorAll('.car-thumb').forEach(x => x.classList.remove('active'));
      firstVisible.classList.add('active');
      const model = firstVisible.dataset.model;
      const vr = firstVisible.dataset.vr || '#';
      switchModel(model, vr);
    }
  });
});

// Initial setup - default to off-road tab
applyCategoryFilter('offroad');
renderColorSwatches('BJ30');
preloadFrames('BJ30', 0, 6);
car360Img.classList.add('loaded');

// ========== WORLD MAP — dealer pin popups ==========
(function(){
  const popup = document.getElementById('dealerPopup');
  if(!popup) return;
  const flagEl = popup.querySelector('.dealer-popup-flag');
  const nameEl = popup.querySelector('.dealer-popup-name');
  const fbEl = popup.querySelector('.dealer-popup-fb');
  const webEl = popup.querySelector('.dealer-popup-web');
  const closeBtn = popup.querySelector('.dealer-popup-close');

  function hidePopup(){ popup.hidden = true; popup.classList.remove('active'); }

  document.querySelectorAll('.dealer-item').forEach(pin => {
    pin.addEventListener('click', e => {
      e.stopPropagation();
      const country = pin.dataset.country || '';
      const code = (pin.dataset.code || '').toLowerCase();
      const fb = pin.dataset.fb || '';
      const web = pin.dataset.web || '';
      nameEl.textContent = country;
      flagEl.style.backgroundImage = code ? `url(https://flagcdn.com/w320/${code}.png)` : '';
      fbEl.style.display = fb ? '' : 'none';
      fbEl.href = fb || '#';
      webEl.style.display = web ? '' : 'none';
      webEl.href = web || '#';
      popup.style.left = pin.style.left;
      popup.style.top = pin.style.top;
      popup.hidden = false;
      requestAnimationFrame(() => popup.classList.add('active'));
    });
  });
  closeBtn.addEventListener('click', e => { e.stopPropagation(); hidePopup(); });
  document.addEventListener('click', e => {
    if(!popup.hidden && !popup.contains(e.target) && !e.target.classList.contains('dealer-item')) hidePopup();
  });
  document.addEventListener('keydown', e => { if(e.key === 'Escape') hidePopup(); });
})();
</script>
