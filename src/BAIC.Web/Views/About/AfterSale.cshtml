@{
    ViewData["Title"] = "After-sales Service";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/after-sale.css" />
}

<!-- HERO -->
<section class="as-hero">
  <img src="https://www.baicglobal.com/_nuxt/after-sale-banner.et4n-X45.jpg" alt="After-Sales Service">
  <div class="as-hero-overlay"></div>
  <div class="as-hero-content">
    <h1>After-Sales Service</h1>
    <p>With our rigorous observation of consumer behavior and our meticulous care for every detail,<br>we strive to understand and satisfy the ever increasing demands of our clients.</p>
  </div>
</section>

<!-- 4 VALUE CARDS -->
<section class="as-values fade-in">
  <div class="as-values-grid">

    <div class="as-card">
      <img src="https://www.baicglobal.com/file/common/image/2022/08/12/1_20220812153444A052.jpg" alt="INTEGRITY">
      <div class="as-card-overlay">
        <h3>INTEGRITY</h3>
        <p>Original spare parts and transparent and reasonable price</p>
      </div>
    </div>

    <div class="as-card">
      <img src="https://www.baicglobal.com/file/common/image/2022/08/12/888888888_20220812171220A082.jpg" alt="WARM">
      <div class="as-card-overlay">
        <h3>WARM</h3>
        <p>Convenient service service dealers and quick repair and maintenance</p>
      </div>
    </div>

    <div class="as-card">
      <img src="https://www.baicglobal.com/file/common/image/2022/08/12/3_20220812155730A072.png" alt="CARE">
      <div class="as-card-overlay">
        <h3>CARE</h3>
        <p>Focus on customer needs and dedicated after-sales service</p>
      </div>
    </div>

    <div class="as-card">
      <img src="https://www.baicglobal.com/file/common/image/2022/08/12/123456_20220812171326A084.jpg" alt="PROFESSIONAL">
      <div class="as-card-overlay">
        <h3>PROFESSIONAL</h3>
        <p>Advanced facilities and professional service team</p>
      </div>
    </div>

  </div>
</section>

<!-- MAP SECTION -->
<section class="as-map fade-in">
  <h3>Multiple After-Sales Service Points Around The World</h3>
  <p class="sub">45 after-sales service channels and 189 service dealers</p>
  <img src="https://www.baicglobal.com/_nuxt/map.DU9VEqCU.png" alt="BAIC After-Sales Service Map">
</section>

<!-- QUESTIONNAIRE SECTION -->
<section class="as-form fade-in">
  <h3>Please Click Yo Fill In The Questionnaire</h3>
  <p class="sub">45 after-sales service channels and 189 service dealers</p>
  <button class="submit-btn">SUBMIT</button>
</section>

@section Scripts {
}
