@{
    ViewData["Title"] = "ESG";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/esg.css" asp-append-version="true" />
}

<!-- PAGE BACKGROUND -->
<img class="page-bg" src="https://www.baicglobal.com/file/public/static/aboutUs/ecp/page_bg.jpg" alt="">

<div class="esg-sections">

  <!-- S1: HERO - kv1 + kv1_title -->
