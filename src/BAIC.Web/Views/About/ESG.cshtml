    <div class="kv2-wrap">
      <img class="kv2" src="https://www.baicglobal.com/file/public/static/aboutUs/ecp/kv2.png" alt="">
      <img class="light-overlay" src="https://www.baicglobal.com/file/public/static/aboutUs/ecp/page2_light.png" alt="">
    </div>
    <div class="s-intro-content">
      <img class="s-intro-logo" src="https://www.baicglobal.com/file/public/static/aboutUs/ecp/kv2_logo.png" alt="BAIC">
