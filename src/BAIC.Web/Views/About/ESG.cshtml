    </div>
  </section>

  <!-- S9: VIDEO kv9 -->
  <section class="s-vid2" id="vidSec9" onclick="toggleVid(this,'vid9')">
    <video id="vid9" muted loop playsinline preload="metadata">
      <source src="https://www.baicglobal.com/file/public/static/aboutUs/ecp/video/kv9.mp4" type="video/mp4">
    </video>
