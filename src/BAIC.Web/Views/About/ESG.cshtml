  </section>

  <!-- Particles -->
  <div class="s-particles">
    <div class="particle" style="background:rgba(100,200,255,.3);border-radius:50%;width:6px;height:6px;left:25%;top:20px"></div>
    <div class="particle" style="background:rgba(100,200,255,.2);border-radius:50%;width:8px;height:8px;left:50%;top:40px;animation-delay:1.5s"></div>
    <div class="particle" style="background:rgba(100,200,255,.25);border-radius:50%;width:5px;height:5px;left:70%;top:25px;animation-delay:3s"></div>
  </div>

  <!-- S2: INTRO - kv2 bg + light overlay + content -->
