      <div class="s-tech-item">
        <img src="https://www.baicglobal.com/file/public/static/aboutUs/ecp/page4_research_01.png" alt="">
        <div class="label">Patents granted:</div>
        <div class="value">1,110</div>
      </div>
      <div class="s-tech-item">
        <img src="https://www.baicglobal.com/file/public/static/aboutUs/ecp/page4_research_02.png" alt="">
