@section Scripts {
<script>
// Animated counter
function animateCounter(el, target, type, duration=1500){
  const start=performance.now();
  function update(now){
    const p=Math.min((now-start)/duration,1);
    const ease=1-Math.pow(1-p,3);
    let val;
    if(type==='year') val=Math.round(1900+ease*(target-1900));
    else if(type==='float') val=(ease*target).toFixed(2);
    else val=Math.round(ease*target);
    el.textContent=val;
    if(p<1) requestAnimationFrame(update);
    else{
      if(type==='float') el.textContent=target.toFixed(2);
      else el.textContent=target;
    }
  }
  requestAnimationFrame(update);
}

// Trigger counters on scroll
const counterObs=new IntersectionObserver((entries)=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('[data-target]').forEach(el=>{
        animateCounter(el,parseFloat(el.dataset.target),el.dataset.type);
      });
      counterObs.unobserve(e.target);
    }
  });
},{threshold:0.3});
document.querySelectorAll('.au-who').forEach(el=>counterObs.observe(el));

// Production carousel
let prodIdx=0;
const prodTrack=document.getElementById('prodTrack');
const prodDots=document.querySelectorAll('.au-prod-dot');
function goToProd(idx){
  prodIdx=Math.max(0,Math.min(idx,3));
  prodTrack.style.transform=`translateX(-${prodIdx*100}%)`;
  prodDots.forEach((d,i)=>d.classList.toggle('active',i===prodIdx));
}
document.getElementById('prodPrev').addEventListener('click',()=>goToProd(prodIdx-1));
document.getElementById('prodNext').addEventListener('click',()=>goToProd(prodIdx+1));
prodDots.forEach(d=>d.addEventListener('click',()=>goToProd(parseInt(d.dataset.idx))));

// Video hover play
document.querySelectorAll('.au-video-item').forEach(item=>{
  const vid=item.querySelector('video');
  item.addEventListener('mouseenter',()=>{if(vid)vid.play()});
  item.addEventListener('mouseleave',()=>{if(vid){vid.pause();vid.currentTime=0}});
});
</script>
}
